[
  {
    "id": "antaisui",
    "title": "安太歲",
    "category": "年度祈福",
    "deities": [
      "taisui"
    ],
    "occasion": "沖犯太歲（生肖值年/沖太歲）",
    "festival_ref": [
      "正月",
      "年尾謝太歲"
    ],
    "steps": [
      {
        "order": 1,
        "action": "至廟方登記，填寫姓名、農曆生日、住址",
        "actor": "信眾",
        "items": [],
        "target": "廟方服務台",
        "note": "廟方據此為信眾點燃太歲燈，掛牌入太歲殿",
        "taboo": []
      },
      {
        "order": 2,
        "action": "備供品，於太歲星君神前陳設",
        "actor": "信眾",
        "items": [
          "清茶三杯",
          "四果",
          "麵線",
          "糖果餅乾"
        ],
        "target": "太歲星君神位",
        "note": "頂桌以素食為主，部分廟宇備壽金、刈金",
        "taboo": [
          "避免供奉葷食"
        ]
      },
      {
        "order": 3,
        "action": "上香，向太歲星君稟報姓名、農曆生辰、住址，說明安太歲事由",
        "actor": "信眾",
        "items": [],
        "target": "太歲星君",
        "note": "一或三柱香，依廟方規定",
        "taboo": []
      },
      {
        "order": 4,
        "action": "擲筊確認太歲星君駕臨",
        "actor": "信眾",
        "items": [],
        "target": "太歲星君",
        "note": "得一正一反聖筊後進行下一步",
        "taboo": []
      },
      {
        "order": 5,
        "action": "香燒至三分之一時，雙手捧持金紙行三拜，燒化金紙禮成",
        "actor": "信眾",
        "items": [
          "壽金",
          "刈金"
        ],
        "target": "太歲星君",
        "note": "部分廟宇有「太歲金」；農曆十二月廿四日前需回廟謝太歲，換新符牌",
        "taboo": [
          "太歲符不可高過神明位階"
        ]
      }
    ],
    "offerings": [
      "清茶",
      "四果",
      "麵線",
      "糖果餅乾"
    ],
    "joss_paper": [
      "壽金",
      "刈金"
    ],
    "taboo": [],
    "regional": [
      {
        "area": "全台通例",
        "note": "農曆正月初一至元宵（最遲二月）前安太歲；立春後最宜；年底農曆十二月廿四日（或歲末送神前）回廟「謝太歲」",
        "sources": [
          {
            "type": "web",
            "ref": "https://www.bailucky.com/an-tai-sui",
            "note": "拜出好運來：安太歲完整流程"
          },
          {
            "type": "web",
            "ref": "https://www.uho.com.tw/article-68873.html",
            "note": "Uho健康：2026安太歲懶人包"
          }
        ]
      },
      {
        "area": "台北（龍山寺、行天宮）",
        "note": "信眾量大，廟方多提供線上登記安太歲；龍山寺太歲殿為北台灣重要據點",
        "sources": [
          {
            "type": "web",
            "ref": "https://chianchi-shop.com.tw/blog/protective-temples-2026-taiwan",
            "note": "2026台北、台中、台南、高雄推薦廟宇整理"
          }
        ]
      },
      {
        "area": "台南（大天后宮、開基武廟）",
        "note": "台南廟宇太歲殿儀式莊嚴隆重，多以書寫疏文、廟方代辦為主",
        "sources": [
          {
            "type": "web",
            "ref": "https://chianchi-shop.com.tw/blog/protective-temples-2026-taiwan",
            "note": "同上"
          }
        ]
      }
    ],
    "summary": "生肖沖犯太歲者，年初至廟安奉太歲星君，年尾謝恩，藉以化解當年厄運。",
    "sources": [
      {
        "type": "web",
        "ref": "https://religion.moi.gov.tw/Knowledge/Content?ci=2&cid=44",
        "note": "內政部全國宗教資訊網：安太歲（條目）"
      },
      {
        "type": "web",
        "ref": "https://www.bailucky.com/an-tai-sui",
        "note": "拜出好運來：家中自安與廟宇代辦兩種方法"
      },
      {
        "type": "web",
        "ref": "https://www.uho.com.tw/article-68873.html",
        "note": "Uho優活健康：2026安太歲懶人包"
      }
    ],
    "draft": false
  },
  {
    "id": "diandeng",
    "title": "點光明燈/平安燈/文昌燈",
    "category": "年度祈福",
    "deities": [
      "wenchang"
    ],
    "occasion": "祈求平安、學業或財運，正月起點燈一年",
    "festival_ref": [
      "正月"
    ],
    "steps": [
      {
        "order": 1,
        "action": "持信眾姓名、出生年月日至廟方服務台登記點燈種類",
        "actor": "信眾",
        "items": [],
        "target": "廟方服務台",
        "note": "光明燈種類包括平安燈、文昌燈、財神燈等，依祈求事項選擇",
        "taboo": []
      },
      {
        "order": 2,
        "action": "繳費，廟方將姓名、農曆生辰、地址書入文疏",
        "actor": "廟方人員",
        "items": [],
        "target": "光明燈燈位",
        "note": "廟方依文疏在燈區點亮對應燈位，定期誦經超薦",
        "taboo": []
      },
      {
        "order": 3,
        "action": "本人親赴上香祈願（若能親至最佳，亦可委由廟方代辦）",
        "actor": "信眾",
        "items": [
          "清茶",
          "四果"
        ],
        "target": "主祀神明",
        "note": "部分廟宇在正月初九、初一及十五舉行誦經法會，代替點燈者祈福",
        "taboo": []
      },
      {
        "order": 4,
        "action": "年底或燈期屆滿前回廟謝燈、收符，完成年度燈期",
        "actor": "信眾",
        "items": [
          "壽金"
        ],
        "target": "主祀神明",
        "note": "謝燈時燒化壽金表達感謝；部分廟宇年度自動續燈需另行告知停燈",
        "taboo": []
      }
    ],
    "offerings": [
      "清茶",
      "四果"
    ],
    "joss_paper": [
      "壽金"
    ],
    "taboo": [],
    "regional": [
      {
        "area": "全台通例",
        "note": "正月初九（天公生）為最多廟宇點燈法會時間；北台灣廟宇多集中於農曆正月初八子時起點燈",
        "sources": [
          {
            "type": "web",
            "ref": "https://religion.moi.gov.tw/Knowledge/Content?ci=2&cid=41",
            "note": "內政部全國宗教資訊網：點光明燈（條目）"
          },
          {
            "type": "web",
            "ref": "https://www.cashfeel.com.tw/article/%E5%AE%89%E5%A4%AA%E6%AD%B2-%E5%85%89%E6%98%8E%E7%87%88-%E8%B2%BB%E7%94%A8",
            "note": "CashFeel安錢感：2026安太歲與光明燈懶人包"
          }
        ]
      },
      {
        "area": "北台灣（龍山寺、行天宮、指南宮）",
        "note": "文昌燈多集中於文昌帝君廟（如指南宮、台北孔廟附近），學生點燈需求旺盛",
        "sources": [
          {
