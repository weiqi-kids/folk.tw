    "deities": [
      "zhusheng",
      "linshui"
    ],
    "occasion": "求子、保胎或民間轉胎性別俗信，至廟拜註生娘娘/臨水夫人",
    "festival_ref": [],
    "steps": [
      {
        "order": 1,
        "action": "至臨水夫人廟或註生娘娘廟告知廟方求子/轉胎心願，安排栽花換斗科儀時間",
        "actor": "信眾（求子者）",
        "items": [],
        "target": "廟方",
        "note": "儀式耗時2至3小時，需由紅頭法師搭配女乩童或道士主持，不可自行操作",
        "taboo": []
      },
      {
        "order": 2,
        "action": "法師請神淨壇，書寫疏文（含主家姓名、生辰八字、所求事項），祭三十六宮婆姐，款待五方十煞",
        "actor": "法師",
        "items": [
          "四果",
          "紅龜粿"
        ],
        "target": "三十六宮婆姐",
        "note": "婆姐象徵嬰孩守護者；此步驟確立儀式神聖空間",
        "taboo": []
      },
      {
        "order": 3,
        "action": "法師造百花橋（以長條木椅幻化），主家持替身繞行三圈、三上三下百花橋，向替身吐氣將穢氣轉移",
        "actor": "信眾/法師",
        "items": [],
        "target": "百花橋/替身",
        "note": "替身從紙紮關限中破關而出，象徵「過關」、「出運」",
        "taboo": []
      },
      {
        "order": 4,
        "action": "法師唸「梗花咒」（「身體健康、花欉勇健、紅花退開，白花著栽」），撕去銅蛇、鐵狗、黃蜂、尾蝶等損花之物",
        "actor": "法師",
        "items": [],
        "target": "信眾花欉",
        "note": "依民俗說法，象徵培植本命花欉、祈求生育機緣；栽花為培植新花叢，剪花為變更性別（剪白花求男、剪紅花求女）",
        "taboo": []
      },
      {
        "order": 5,
        "action": "法師詢問期盼子嗣性別人數，剪下花叢上對應花朵，以紅紙包覆；主家將供案上花摘下做髮夾插戴三晚後收藏",
        "actor": "信眾/法師",
        "items": [
          "刈金",
          "壽金"
