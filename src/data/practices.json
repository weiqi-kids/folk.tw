  {
    "id": "shoujing",
    "title": "收驚",
    "category": "解厄",
    "deities": [
      "zushen"
    ],
    "occasion": "受驚嚇或嬰幼兒夜啼，請廟方或婆姆以米卦/香米收魂",
    "festival_ref": [],
    "steps": [
      {
        "order": 1,
        "action": "至廟方或神壇說明收驚事由（受驚嚇、嬰兒夜啼、長期不安等），攜帶受術者衣物",
        "actor": "信眾/家屬",
        "items": [],
        "target": "廟方執事者、法師或婆姆",
        "note": "行天宮等大廟由志工執行，各廟無統一SOP；部分神壇可到府",
        "taboo": []
      },
      {
        "order": 2,
        "action": "執事者點香，取受術者衣物與觀魂米備用",
        "actor": "法師/婆姆/廟方執事",
        "items": [],
        "target": "受術者（本人或衣物代替）",
        "note": "香米（觀魂米）是閩南最普遍做法；道教法師亦使用符籙",
        "taboo": []
      },
      {
        "order": 3,
        "action": "唸收驚咒，以香米在受術者頭部、身前身後比劃，或畫符加持",
        "actor": "法師/婆姆/廟方執事",
        "items": [],
        "target": "受術者",
        "note": "完整法師施術包含：灑淨、開鞭、摔鹽米、唸收驚咒、打指；輕症可僅唸咒",
        "taboo": [
          "農曆七月（鬼月）一般不宜收驚，恐引入不淨"
        ]
      },
      {
        "order": 4,
        "action": "觀察香米紋路判斷沖犯原因，告知家屬",
        "actor": "法師/婆姆/廟方執事",
        "items": [],
        "target": "家屬",
        "note": "米堆上的紋路可解釋驚著原因（各法師判讀方式不同）",
        "taboo": []
      },
      {
        "order": 5,
        "action": "化紙（焚燒刈金），完成科儀",
        "actor": "信眾/法師",
        "items": [
          "刈金"
        ],
        "target": "神明/地方神",
        "note": "重症需加做祭解、補運；嬰兒收驚後衣物通常繼續穿戴幾日",
        "taboo": []
      }
    ],
    "offerings": [],
    "joss_paper": [
      "刈金"
    ],
    "taboo": [],
    "regional": [
      {
        "area": "閩南（全台各地廟宇）",
        "note": "最常見做法為香米收驚：執事者持米在受術者周身比劃，再觀米判因；行天宮等廟宇有標準化志工服務",
        "sources": [
          {
            "type": "web",
            "ref": "https://vocus.cc/article/67f68c35fd897800018d5e96",
            "note": "方格子：收驚的民俗奇幻冒險（閩南廟宇做法）"
          },
          {
            "type": "web",
            "ref": "https://www.lesson.com.tw/blog/detail/102",
            "note": "台灣文民：神奇的收驚"
          }
        ]
      },
      {
        "area": "道教紅頭法師（閩南、北部）",
        "note": "複雜科儀含灑淨、開鞭、摔鹽米、唸收驚咒、打指、化紙；視嚴重程度分輕症（小收）與重症（大收，含祭煞、送草人）",
        "sources": [
          {
            "type": "web",
            "ref": "https://hef.org.tw/journal374-5/",
            "note": "人本教育基金會374期：收驚面面觀"
          },
          {
            "type": "web",
            "ref": "https://vocus.cc/article/67f68c35fd897800018d5e96",
            "note": "方格子：收驚的民俗奇幻冒險"
          }
        ]
      },
      {
        "area": "家族私傳（客家、各地）",
        "note": "部分農村家庭有家傳收驚法，咒語、手法只在家族內流傳，不公開傳授，偏向原始巫醫不分形態；此類做法地區差異大，無統一記載",
        "sources": [
          {
            "type": "web",
            "ref": "https://hef.org.tw/journal374-5/",
            "note": "人本教育基金會374期：收驚面面觀"
          }
        ]
      }
    ],
    "summary": "受驚嚇者或夜啼嬰幼兒，請廟方乩童、婆姆以香米或米卦行收驚科儀，安定魂魄。",
    "sources": [
      {
        "type": "web",
        "ref": "https://vocus.cc/article/67f68c35fd897800018d5e96",
