  {
    "id": "anshenwei",
    "title": "安神位/安公媽",
    "category": "居家",
    "deities": [
      "zushen"
    ],
    "occasion": "入厝或年節時安置家神神桌、爐位，並行晉火儀式",
    "festival_ref": [
      "入厝時",
      "年節"
    ],
    "steps": [
      {
        "order": 1,
        "action": "翻農民曆擇「安香」吉日，避開沖煞家主生肖之日時",
        "actor": "信眾/擇日師",
        "items": [],
        "target": "神桌、神位空間",
        "note": "多選上午7至11時陽氣旺盛時段",
        "taboo": [
          "日時煞向不可沖神明坐向"
        ]
      },
      {
        "order": 2,
        "action": "確定神位方向，靠實牆、避對廁所廚房樓梯，神桌正上方不宜橫梁",
        "actor": "信眾/風水師",
        "items": [],
        "target": "神桌位置",
        "note": "神桌不可懸空或背對窗戶",
        "taboo": [
          "神桌正上方忌橫梁、廁所、樓梯"
        ]
      },
      {
        "order": 3,
        "action": "安爐：用七張壽金淨爐，爐內放五寶，鋪香灰，插香默唸「安爐大吉，神光普照」",
        "actor": "法師/信眾",
        "items": [
          "壽金"
        ],
        "target": "神明香爐",
        "note": "捧神像繞香爐三遍，喊「進財！進官！進祿！」；神明爐兩側無耳，公媽爐兩側有耳，不可混淆",
        "taboo": [
          "神明爐與公媽爐不可互換"
        ]
      },
      {
        "order": 4,
        "action": "全家點香，向外呼請神明及祖先降臨，將香插入各爐，請神位「過爐香」後安座調正",
        "actor": "全家大小",
        "items": [],
        "target": "神明、祖先牌位",
        "note": "祖先牌位不可高於神像；不同姓氏祖先以紅線隔開",
        "taboo": [
          "祖先牌位不可高於神明"
        ]
      },
      {
        "order": 5,
        "action": "上供品祭拜，行三叩禮，燒化金紙完成安神",
        "actor": "信眾",
        "items": [
          "三牲",
          "四果",
          "發粿",
          "米糕",
          "清茶"
        ],
        "target": "神明、祖先",
        "note": "同日下午1至5時另拜地基主（備便菜三樣、兩碗飯、酒三杯）",
        "taboo": []
      }
    ],
    "offerings": [
