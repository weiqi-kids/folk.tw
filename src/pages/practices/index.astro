---
import Base from '../../layouts/Base.astro';
import { getPractices } from '../../lib/queries';
import { breadcrumb } from '../../lib/seo';

const practices = await getPractices();
const byCat = new Map<string, typeof practices>();
for (const p of practices) {
  const c = p.data.category;
  (byCat.get(c) ?? byCat.set(c, []).get(c)!).push(p);
}
---

<Base
  title="拜拜習俗／科儀"
  description="安太歲、點光明燈、普渡、做十六歲等習俗：步驟、金紙供品、諸說並陳。"
  jsonLd={breadcrumb([{ name: '拜拜習俗', path: '/practices' }])}
>
  <h1>拜拜習俗／科儀</h1>
  <p class="muted">
    拜拜習俗與科儀的步驟知識庫；部分條目的步驟與地方差異仍在補齊掛源中。
  </p>
  <p class="links">
    <a href="/jiaobei/">擲筊判讀 →</a>　<a href="/vocabulary/">金紙·供品·陣頭受控詞彙 →</a>
  </p>
  {
    [...byCat.entries()].map(([cat, list]) => (
      <section>
        <h2>{cat}</h2>
        <div class="grid cols">
          {list.map((p) => (
            <a
              class:list={['card', { 'card-photo': p.data.image }]}
              href={`/practices/${p.id}/`}
            >
              <strong>{p.data.title}</strong>
              {p.data.summary && <div class="muted small">{p.data.summary}</div>}
              {p.data.image && (
                <img
                  class="card-photo-img"
                  src={p.data.image.src}
                  alt={p.data.image.alt}
                  title={`圖：${p.data.image.author}　·　${p.data.image.license}（Wikimedia Commons，詳見關於頁）`}
                  width="72"
                  height="72"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </a>
          ))}
        </div>
      </section>
    ))
  }
  <style>
    h2 { border-bottom: 1px solid var(--accent-soft); padding-bottom: 0.375rem; }
    .card strong { color: var(--ink); }
    .small { font-size: var(--text-base); margin-top: 0.25rem; }
    .card .muted { color: oklch(0.37 0.02 72); }
  </style>
</Base>
