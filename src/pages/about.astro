---
import Base from '../layouts/Base.astro';
import { breadcrumb } from '../lib/seo';

// 常見問答（AEO：問答友善＋FAQPage schema）
const faqs = [
  { q: '神酷（神庫）是什麼？', a: '神酷是台灣漢人民間信仰的結構化考據知識系統，涵蓋籤詩解讀、神明關係圖譜、廟宇文化、農民曆與拜拜習俗，資料逐條掛來源、諸說並陳。' },
  { q: '籤詩的分項解準不準？', a: '神酷的分項解與白話賞析是本站原創的文化解讀，以「文化呈現」框架呈現，不對個人預言吉凶、不構成命理建議；現代解籤文字有著作權，本站不抄錄。' },
  { q: '農民曆的宜忌依據是什麼？', a: '宜忌依《欽定協紀辨方書》（四庫全書本）逐條考據化，每條附推導（由哪些神煞、依何規則）與卷數出處；未經原文核校者不對外顯示。' },
  { q: '資料來源可靠嗎？', a: '每筆事實掛來源、無源不發佈；爭議處諸說並陳、不裁定正統；公有領域本文可收錄並標版本。' },
  { q: '涵蓋哪些範圍？', a: '以漢人民間信仰為主（海神／開拓神／族群神／行業神／愛情婦幼／動物神／自然神 七大類），非窮盡台灣所有宗教信仰。' },
];
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="關於與勘誤"
  description="神酷（神庫）的定位、使用邊界與免責、範圍身分聲明、版權授權、勘誤回報與常見問答。"
  jsonLd={[faqLd, breadcrumb([{ name: '關於與勘誤', path: '/about' }])]}
>
  <h1>關於神酷（神庫）</h1>
  <p class="lead">
    本站是<strong>台灣民俗信仰的考據工具</strong>：把籤詩、神明、農民曆、民俗活動與拜拜習俗，
    做成逐條掛來源、諸說並陳的結構化知識。我們賣「看懂文化」，不賣「預言吉凶」。
  </p>

  <section>
    <h2>常見問答</h2>
    {
      faqs.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))
    }
  </section>

  <section>
    <h2>使用邊界與免責</h2>
    <p>
      本站為民俗文化考據與教育呈現，<strong>不構成醫療、法律、投資、命理或宗教指導建議</strong>。
      涉宜忌、籤詩分項（疾病／訴訟／求財）、改運／收驚／安太歲、神煞吉凶等，皆以「文化呈現」框，不以「建議」語氣。
    </p>
    <p>凡內容涉健康、法律、財務、心理，請洽專業人士。本站不勸阻、不背書、不替代專業判斷。</p>
    <h3>責任限制</h3>
    <p>
      本站內容（含籤詩白話、宜忌、神明與民俗資料）僅供文化教育與學術參考，
      <strong>依現況「按其原樣」提供，不就正確性、完整性或特定用途之適用性作任何明示或默示擔保</strong>。
      使用者就其依本站內容所為之決定與行動<strong>自負全部風險</strong>；於法律許可範圍內，本站及編作者
      對任何直接或間接損害不負賠償責任。資料若有錯誤或爭議，歡迎透過勘誤管道回報更正。
    </p>
    <p>
      本站為純靜態網站，本身不蒐集個人資料；全文檢索於使用者瀏覽器端運作。
      為了解流量與改善內容，本站使用 <strong>Google Analytics 4</strong> 進行匿名統計
      （已啟用 IP 匿名化）；相關資料由 Google 依其隱私政策處理，您可透過瀏覽器設定或
      Google 之停用工具拒絕。本站不販售亦不用於廣告投放。
    </p>
    <p class="muted small">以上免責、責任限制與使用條款已確認定稿（§13.1／§13.6.1）。</p>
  </section>

  <section>
    <h2>負面結果的呈現</h2>
    <p>
      凶籤、凶宜忌、疾病／訴訟分項，以文化脈絡與解讀呈現，避免命令式斷言；
      不對個人處境預言禍福、不臆測使用者真實狀況。內容涉困境處，提供中性、非引導的求助方向。
    </p>
  </section>

  <section>
    <h2>編輯尊重與廟際敏感</h2>
    <p>
      面向信眾語氣莊重，不褻瀆、不戲謔、不以神明與儀俗為哏。
      廟際爭議（分靈、位階、信仰圈、正統之爭）一律諸說並陳、不選邊、不裁定正統。
      神格位階不建模、不排高低，只記分類與關係。
    </p>
  </section>

  <section>
    <h2>範圍與身分聲明</h2>
    <p>
      本站涵蓋以<strong>漢人民間信仰</strong>為主（海神／開拓神／族群神／行業神／愛情婦幼／動物神／自然神 七大類），
      <strong>非窮盡台灣所有宗教信仰</strong>；未涵蓋原住民族傳統信仰、佛教各宗、一貫道、新興宗教等。
    </p>
  </section>

  <section>
    <h2>版權與授權</h2>
    <ul>
      <li>籤詩四句本文：多屬公有領域，直接收錄並標明系統／版本。</li>
      <li>現代「解籤」文字：常有著作權，<strong>本站不抄錄</strong>；分項解自行撰寫。</li>
      <li>典故故事：取公有領域題材（史記、演義等）自行敘述，不抄特定改寫本。</li>
      <li>神明事實（聖誕、職司）：事實不受著作權保護，但逐條引來源佐證。</li>
      <li>內政部寺廟開放資料：依政府資料開放授權條款使用、標示來源。</li>
    </ul>
    <p class="muted small">程式碼採開源授權（見原始碼庫 LICENSE）；資料來源逐條標註於各條目。</p>
  </section>

  <section>
    <h2>可信度與勘誤</h2>
    <p>
      本站每條目具來源標註。發現錯誤（事實、來源或判讀）歡迎回報；
      查證後更正並記版本／更新日，重大爭議內容標「諸說並陳／待考」。
    </p>
    <p class="errata">
      <strong>勘誤回報：</strong>
      <a href="https://github.com/weiqi-kids/folk.tw/issues/new" target="_blank" rel="noopener">於 GitHub 開 Issue 回報 →</a>
      （亦歡迎廟方、研究者指正；請附條目與來源依據。）
    </p>
  </section>

  <style>
    .lead { font-size: 1.1rem; }
    h2 { border-bottom: 1px solid var(--accent-soft); padding-bottom: 0.3rem; margin-top: 1.8rem; }
    .small { font-size: 0.85rem; }
    li { margin: 0.3rem 0; }
    .faq { border-bottom: 1px dashed var(--line); padding: 0.5rem 0; }
    .faq summary { cursor: pointer; font-weight: 700; color: var(--ink); }
    .faq p { margin: 0.5rem 0 0; color: var(--ink-soft); }
  </style>
</Base>
