---
import Base from '../../layouts/Base.astro';
import { computeDayRecord } from '../../lib/almanac';
import { lunarProvider } from '../../lib/almanac/provider';
import { todayInTaipei } from '../../lib/daily';
import { deityBirthdayIndex } from '../../lib/queries';

// 今日農民曆（UTC+8）。核心層已接 lunar-javascript（對齊香港天文台）→ 點亮農曆/節氣/四柱/
// 建除/廿八宿/沖煞/節日/聖誕（verified）。進階層宜忌/神煞/黃黑道/胎神仍待《協紀辨方書》考據化（C.6）。
const { iso } = todayInTaipei();
const [y, m, dd] = iso.split('-').map(Number);

// 神明聖誕 join（C.3）：先算今日農曆，再 join 具名實例之 birthday_lunar（MM-DD）
const provisional = computeDayRecord(y, m, dd, { astro: lunarProvider });
const lunar = provisional.lunar.value;
const bdayIndex = await deityBirthdayIndex();
const lunarKey = lunar ? `${String(lunar.month).padStart(2, '0')}-${String(lunar.day).padStart(2, '0')}` : '';
const birthdays = (bdayIndex.get(lunarKey) ?? []) as { deityId: string; name: string }[];

const record = computeDayRecord(y, m, dd, { astro: lunarProvider, deityBirthdays: birthdays });
const P = record.pillars;
const gz = (p: { value: { stem: string; branch: string } | null }) => (p.value ? `${p.value.stem}${p.value.branch}` : '—');

// 進階層：只對外顯示已 verified（考據化核校通過）者；未核者僅透明計數（C.7.8 無源不顯示）
const yiV = record.yi.filter((v) => v.verified);
const jiV = record.ji.filter((v) => v.verified);
const hhV = record.huangHeiDao.verified ? record.huangHeiDao.value : null;
const tsV = record.taiShen.verified ? record.taiShen.value : null;
const pendingCount =
  record.yi.length + record.ji.length - yiV.length - jiV.length +
  (record.huangHeiDao.value && !record.huangHeiDao.verified ? 1 : 0);
const hasVerifiedAdv = yiV.length + jiV.length > 0 || hhV || tsV;
---

<Base title={`農民曆 · ${iso}`} description="農曆、節氣、四柱、建除、廿八宿、沖煞、神明聖誕；宜忌考據化（建置中）。">
  <h1>農民曆 · {iso}</h1>
  <p class="muted">
    本模組與市面農民曆 app 的分水嶺：宜忌不只給結論，而是給「依《協紀辨方書》某神煞」的推導與出處，
    長在<strong>考據身分</strong>上而非滑向算命（C.6）。核心層已接天文資料；宜忌進階層考據化建置中。
  </p>

  {/* 核心層 — 已接 lunar-javascript（對齊香港天文台），verified */}
  <section>
    <h2>今日（核心層）</h2>
    <dl class="rec">
      <div><dt>國曆</dt><dd>{iso}（UTC+8）</dd></div>
      <div>
        <dt>農曆</dt>
        <dd>{lunar ? `${lunar.isLeap ? '閏' : ''}${lunar.month} 月 ${lunar.day} 日` : '—'}</dd>
      </div>
      <div><dt>節氣</dt><dd>{record.solarTerm.value?.name ?? '—'}{record.solarTerm.value?.isTransitionDay && '（交節）'}</dd></div>
      <div><dt>四柱</dt><dd>{gz(P.year)}年 {gz(P.month)}月 {gz(P.day)}日　<span class="warn small">時柱需真太陽時 C.6</span></dd></div>
      <div><dt>建除</dt><dd>{record.jianchu.value ?? '—'}</dd></div>
      <div><dt>廿八宿</dt><dd>{record.ershiba.value ?? '—'}</dd></div>
      <div>
        <dt>沖煞</dt>
        <dd>沖 {record.chongSha.value?.zodiac ?? '—'}　{record.chongSha.value?.direction ?? ''}</dd>
      </div>
      {record.festivals.length > 0 && <div><dt>節日</dt><dd>{record.festivals.join('、')}</dd></div>}
      <div>
        <dt>神明聖誕</dt>
        <dd>
          {birthdays.length > 0
            ? birthdays.map((b, i) => (<>{i > 0 && '、'}<a href={`/deities/${b.deityId}`}>{b.name}</a></>))
            : <span class="muted">今日無（具名實例聖誕）</span>}
        </dd>
      </div>
    </dl>
    <p class="src small">
      農曆／節氣／干支：lunar-javascript（壽星天文曆算法，對齊香港天文台）；日柱與廿八宿錨定常數已跨源校準
      （calibration.test，15+ 日交叉驗證）。發佈前建議再對中央氣象署官方農民曆抽查（C.4-4）。
    </p>
  </section>

  {/* 進階層 — 考據化（C.6）：引擎已推得，只顯示 verified 者 */}
  <section>
    <h2>宜忌・神煞（進階層・考據化）</h2>
    {
      hasVerifiedAdv ? (
        <>
          {(yiV.length > 0 || jiV.length > 0) && (
            <div class="yiji">
              {yiV.length > 0 && (
                <p><strong class="yi">宜</strong>　{yiV.map((v) => v.affair).join('、')}</p>
              )}
              {jiV.length > 0 && (
                <p><strong class="ji">忌</strong>　{jiV.map((v) => v.affair).join('、')}</p>
              )}
              <details class="deriv">
                <summary>推導與出處（考據化）</summary>
                <ul>
                  {[...yiV, ...jiV].map((v) => (
                    <li>
                      <strong>{v.affair}</strong> {v.judgement}：{v.resolvedBy}
                      <span class="src small">　{v.sources.join('；')}</span>
                    </li>
                  ))}
                </ul>
              </details>
            </div>
          )}
          {hhV && <p>黃黑道：{hhV.name}（{hhV.auspicious ? '黃道吉' : '黑道凶'}）</p>}
          {tsV && <p>胎神占方：{tsV}</p>}
        </>
      ) : (
        <p class="pending">
          引擎已依《協紀辨方書》規則推得今日神煞、黃黑道、宜忌與胎神（含 derivation＋sources），
          但規則表 <strong>verified:false</strong>——古文轉錄待人工核對《欽定協紀辨方書》後始對外顯示
          （§5／C.6／C.7.8 無源不顯示）。{pendingCount > 0 && `今日待核條目：${pendingCount}。`}
          這正是本站「考據而非算命」的分水嶺：寧可暫不顯示，不放未經核校之斷語。
        </p>
      )
    }
    <p class="muted small">
      時柱／時辰宜忌需真太陽時（經度＋均時差），列發佈後增補（C.6）。
    </p>
  </section>

  <section>
    <h2>曆算基準宣告（C.8）</h2>
    <dl class="rec">
      <div><dt>日界</dt><dd>民用日 00:00 換日；四柱日柱若依命理子初換日另標基準，不與民用日混用。</dd></div>
      <div><dt>時區</dt><dd>農曆／節氣／定朔一律以東經 120°（UTC+8）為準；「今日」以 UTC+8 當日計。</dd></div>
      <div><dt>閏月聖誕</dt><dd>聖誕逢閏月年仍歸該月之正月（如閏三月仍以正三月計）；他俗諸說並陳。</dd></div>
      <div><dt>有效年限</dt><dd>農曆演算採 lunar-javascript 涵蓋範圍；超出回「超出曆算範圍」，不外推硬算。</dd></div>
    </dl>
  </section>

  <style>
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-top: 1.8rem; }
    .small { font-size: 0.85rem; }
    .rec { display: grid; gap: 0.4rem; }
    .rec > div { display: grid; grid-template-columns: 6rem 1fr; gap: 0.5rem; padding: 0.3rem 0; border-bottom: 1px dashed var(--line); }
    .rec dt { font-weight: 700; color: var(--accent); }
    .rec dd { margin: 0; }
    .warn { color: var(--gold); }
    .src { color: var(--gold); margin-top: 0.8rem; }
    .todo { padding-left: 1.2rem; }
    code { background: var(--paper-2); padding: 0 0.3rem; border-radius: 0.2rem; }
    .yiji p { margin: 0.4rem 0; font-size: 1.05rem; }
    .yi { display: inline-block; min-width: 1.6rem; text-align: center; color: #2e6b3a; border: 1px solid #9bbf9b; border-radius: 0.3rem; }
    .ji { display: inline-block; min-width: 1.6rem; text-align: center; color: var(--accent); border: 1px solid var(--accent-soft); border-radius: 0.3rem; }
    .deriv { margin: 0.6rem 0; }
    .deriv summary { cursor: pointer; color: var(--ink-soft); font-size: 0.9rem; }
    .deriv li { padding: 0.2rem 0; font-size: 0.9rem; }
  </style>
</Base>
