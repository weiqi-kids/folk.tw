---
import Base from '../../layouts/Base.astro';
import AlmanacDay from '../../components/AlmanacDay.astro';
import { todayInTaipei } from '../../lib/daily';

// 今日農民曆（UTC+8）。可前後翻頁或直接挑日期瀏覽（見 /almanac/[date]）。
const { iso } = todayInTaipei();
---

<Base
  title={`農民曆 · ${iso}`}
  description="每日農曆、節氣、干支、建除、廿八宿、沖煞與神明聖誕，可瀏覽任一日期。"
>
  <AlmanacDay iso={iso} today={iso} />
</Base>
