---
import Base from '../../layouts/Base.astro';
import { getEvents, getDeities } from '../../lib/queries';
import { breadcrumb } from '../../lib/seo';

const events = await getEvents();
const deities = await getDeities();
const deityName = new Map(deities.map((d) => [d.id, d.data.name]));
const HERITAGE: Record<string, string> = {
  national_important: '國家重要民俗',
  municipal: '直轄市定民俗',
  county: '縣市定民俗',
  none: '未登錄',
};
const CYCLE: Record<string, string> = {
  annual: '每年',
  n_year_ke: '數年一科',
  irregular: '不定期',
};
// 依文資身分分三段（國家重要 → 直轄市定 → 縣市定），段內維持既有 curated 檔案序。
const LEVELS = ['national_important', 'municipal', 'county', 'none'] as const;
const groups = LEVELS.map((level) => ({
  level,
  label: HERITAGE[level],
  items: events.filter((e) => (e.data.heritage?.level ?? 'none') === level),
})).filter((g) => g.items.length > 0);
---

<Base
  title="民俗活動／繞境"
  description="遶境進香、迎王、中元普渡等民俗活動：主神、文資身分、路線型態。"
  jsonLd={breadcrumb([{ name: '民俗活動', path: '/events' }])}
>
  <h1>民俗活動／繞境</h1>
  <p class="muted">
    台灣各地遶境、進香、迎王、中元普渡等民俗活動一覽：依文資身分分級，並列主神、舉行時序與路線型態。
  </p>
  {
    groups.map((g) => (
      <section class="ev-section">
        <h2>
          {g.label}
          <span class="count muted">（{g.items.length}）</span>
        </h2>
        <div class="ev-grid">
          {g.items.map((e) => (
            <a class:list={['card', 'ev', { 'card-photo': e.data.image }]} href={`/events/${e.id}`}>
              <strong>{e.data.name}</strong>
              <div class="muted small when">
                {CYCLE[e.data.cycle]}
                {e.data.date_note && `　·　${e.data.date_note}`}
              </div>
              <div class="muted small">
                主神：{deityName.get(e.data.main_deity) ?? e.data.main_deity}
                {e.data.region.length > 0 && `　·　${e.data.region.join('、')}`}
              </div>
              <div class="chips">
                {e.data.type.map((t) => (
                  <span class="tag">{t}</span>
                ))}
                {e.data.heritage && !e.data.heritage.verified && <span class="tag">待核</span>}
              </div>
              {e.data.image && (
                <img
                  class="card-photo-img"
                  src={e.data.image.src}
                  alt={e.data.image.alt}
                  title={`圖：${e.data.image.author}　·　${e.data.image.license}（Wikimedia Commons，詳見關於頁）`}
                  width="72"
                  height="72"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </a>
          ))}
        </div>
      </section>
    ))
  }
  <style>
    .ev-section h2 {
      border-bottom: 1px solid var(--accent-soft);
      padding-bottom: 0.3rem;
      margin-top: 1.8rem;
    }
    .count { font-size: 0.85rem; font-weight: 400; }
    .ev-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
      gap: 0.8rem;
      margin-top: 1rem;
    }
    .ev { display: flex; flex-direction: column; gap: 0.3rem; }
    .ev strong { color: var(--ink); font-size: 1.05rem; }
    .small { font-size: 0.98rem; } /* 年長者友善：放大 */
    .ev .muted { color: oklch(0.37 0.02 72); } /* 次要文字加深 */
    .ev .when { color: var(--accent); } /* 時序：深朱紅（順序在後勝出） */
    .chips { margin-top: 0.1rem; }
    /* 斜切底圖呈現＝全站共用 .card-photo（見 global.css）；此頁沿用預設 70%×50% */
  </style>
</Base>
