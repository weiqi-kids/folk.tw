---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import Sources from '../../components/Sources.astro';
import { getTrades, getDeities, templesByDeity } from '../../lib/queries';
import { breadcrumb, faqPage } from '../../lib/seo';
import { todayInTaipei } from '../../lib/daily';
import { addDays, almanacHref } from '../../lib/almanac/dates';
import { verifiedYiDays, affairNameOf } from '../../lib/almanac/select';

export const getStaticPaths = (async () => {
  const trades = await getTrades();
  const deities = await getDeities();
  const deityById = new Map(deities.map((d) => [d.id, d]));
  const tByDeity = await templesByDeity();
  const { iso } = todayInTaipei();
  return trades.map((t) => ({
    params: { slug: t.id },
    props: { trade: t, deityById, tByDeity, today: iso },
  }));
}) satisfies GetStaticPaths;

const { trade, deityById, tByDeity, today } = Astro.props;
const t = trade.data;

// 守護神卡：join 神明節點（integrity 已硬驗 deity_ref 存在；publishable gate 後仍防缺）
const patrons = t.patrons
  .map((p) => ({ ...p, deity: deityById.get(p.deity_ref) }))
  .filter((p) => p.deity);

// 近期吉日（今日起 60 天）：僅 verified 條目（M3，經 select.ts 唯一入口）
const next60 = Array.from({ length: 60 }, (_, i) => addDays(today, i));
const yiDays = verifiedYiDays(next60, t.affairs_yi);
const fmt = (iso: string) => `${Number(iso.slice(5, 7))}/${Number(iso.slice(8))}`;
const monthHref = `/almanac/month/${today.slice(0, 7)}/`;

// 聖誕（農曆）：僅實際日期（同神明頁規則）
const bdaysOf = (p: (typeof patrons)[number]) =>
  p.deity!.data.birthday_lunar.filter(
    (b) => b.kind === '聖誕' && b.date && !['無定', '待查', '未定'].includes(b.date),
  );

// FAQ（AEO）：僅就既有資料生成，無源不杜撰（§5）
const faqItems: { q: string; a: string }[] = [
  {
    q: `${t.name}拜什麼神？`,
    a: `${t.name}常奉之守護神：${patrons.map((p) => `${p.deity!.data.name}（${p.role}）`).join('、')}。`,
  },
  {
    q: `${t.name}守護神的聖誕是哪一天？`,
    a: patrons
      .flatMap((p) => bdaysOf(p).map((b) => `${p.deity!.data.name}聖誕為農曆${b.date}`))
      .join('；'),
  },
  {
    q: `近期哪些日子適合${t.affairs_yi.map((a) => affairNameOf(a)).join('、')}？`,
    a: t.affairs_yi
      .filter((a) => (yiDays.get(a) ?? []).length > 0)
      .map((a) => `宜${affairNameOf(a)}：${yiDays.get(a)!.slice(0, 5).join('、')}`)
      .join('；'),
  },
];
const faq = faqPage(faqItems);
const jsonLd = [
  breadcrumb([
    { name: '行業守護神', path: '/trades' },
    { name: t.name, path: `/trades/${trade.id}` },
  ]),
  ...(faq ? [faq] : []),
];
---

<Base
  title={`${t.name}拜什麼神？守護神與吉日`}
  description={`${t.description}守護神：${patrons.map((p) => p.deity!.data.name).join('、')}。`}
  ogType="article"
  jsonLd={jsonLd}
  speakable={['h1', '.lead']}
>
  <nav class="crumb"><a href="/trades/">行業守護神</a> ／ {t.name}</nav>

  <header class="dh">
    <h1>{t.name}的守護神與吉日</h1>
    {t.modern && <p class="aliases"><span class="tag">現代延伸</span></p>}
  </header>

  <p class="lead">{t.description}</p>
  {
    t.modern && (
      <p class="muted small">
        本頁為傳統祖師信仰的現代延伸視角：行業本身為現代職業，所列奉祀傳統均出自可查證之既有信仰
        （各條掛源），非本站新創。
      </p>
    )
  }

  <section>
    <h2>守護神</h2>
    {
      patrons.map((p) => {
        const d = p.deity!.data;
        const bdays = bdaysOf(p);
        const temples = (tByDeity.get(p.deity_ref) ?? []).slice(0, 6);
        return (
          <div class="patron">
            <p class="patron-head">
              <a href={`/deities/${p.deity_ref}/`}><strong>{d.name}</strong></a>
              <span class="tag">{p.role}</span>
              {d.office.slice(0, 3).map((o) => (
                <span class="tag soft">{o}</span>
              ))}
            </p>
            <p>{p.why}</p>
            {bdays.length > 0 && (
              <p class="muted small">聖誕（農曆）：{bdays.map((b) => b.date).join('、')}</p>
            )}
            {temples.length > 0 && (
              <p class="muted small">
                主祀廟宇：
                {temples.map((tp, i) => (
                  <>
                    {i > 0 && '、'}
                    <a href={`/temples/${tp.id}/`}>{tp.data.name}</a>
                  </>
                ))}
                {(tByDeity.get(p.deity_ref) ?? []).length > 6 && (
                  <a href={`/deities/${p.deity_ref}/`}>　…看全部 →</a>
                )}
              </p>
            )}
            <p class="src"><Sources sources={p.sources} /></p>
          </div>
        );
      })
    }
  </section>

  <section>
    <h2>近期吉日（今日起 60 天）</h2>
    {
      t.affairs_yi.map((a) => {
        const days = yiDays.get(a) ?? [];
        return (
          <div class="affair-days">
            <strong>宜{affairNameOf(a)}</strong>
            {days.length > 0 ? (
              <span class="chips">
                {days.map((iso) => (
                  <a class="chip" href={almanacHref(iso, today)}>{fmt(iso)}</a>
                ))}
              </span>
            ) : (
              <span class="muted small">近 60 天內無已驗證之宜日。</span>
            )}
          </div>
        );
      })
    }
    <p class="muted small">
      完整逐日宜忌見 <a href={monthHref}>本月農民曆</a>。
    </p>
  </section>

  <section>
    <h2>本行業相關宜忌事項</h2>
    <p>
      宜側觀察：{t.affairs_yi.map((a) => <span class="tag">{affairNameOf(a)}</span>)}
      {t.affairs_ji.length > 0 && <>　忌側觀察：{t.affairs_ji.map((a) => <span class="tag soft">{affairNameOf(a)}</span>)}</>}
    </p>
    <p class="muted small">
      逐日詳情與推導出處見 <a href={monthHref}>本月農民曆</a> 或 <a href="/almanac/">今日農民曆</a>。
    </p>
  </section>

  {t.sources.length > 0 && <p class="src footer-src"><Sources sources={t.sources} /></p>}

  <style>
    .crumb { color: var(--ink-soft); font-size: var(--text-sm); margin-bottom: 0.625rem; }
    .dh h1 { margin: 0.25rem 0 0.5rem; }
    .lead { font-size: var(--text-base); }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.375rem; margin-top: 2rem; }
    .patron { padding: 0.75rem 0; border-bottom: 1px dashed var(--line); }
    .patron-head { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin: 0; }
    .tag.soft { color: var(--ink-soft); }
    .affair-days { padding: 0.4375rem 0; }
    .chips { display: inline-flex; flex-wrap: wrap; gap: 0.375rem; margin-left: 0.625rem; }
    .chip {
      padding: 0.125rem 0.625rem; border: 1px solid var(--line); border-radius: 0.5rem;
      background: var(--paper-2); font-size: var(--text-sm);
    }
    .chip:hover { text-decoration: none; border-color: var(--accent-soft); }
    .src { color: var(--gold); font-size: var(--text-xs); }
    .small { font-size: var(--text-sm); }
    .footer-src { margin-top: 2.5rem; }
  </style>
</Base>
