---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getPoems, getAllusions, getSystems, interpretationById, allusionNameById, deitiesBySystem, poemsBySystem } from '../../lib/queries';
import { breadcrumb, poemWork, faqPage } from '../../lib/seo';

export const getStaticPaths = (async () => {
  const poems = await getPoems();
  const interps = await interpretationById();
  return poems.map((p) => ({ params: { id: p.id }, props: { poem: p, interp: interps.get(p.id) } }));
}) satisfies GetStaticPaths;

const { poem, interp } = Astro.props;
const d = poem.data;

const allusions = await getAllusions();
const allusionById = new Map(allusions.map((a) => [a.id, a]));
const allusionName = await allusionNameById(); // 不過濾 draft，供顯示典故名
const systems = await getSystems();
const systemName = new Map(systems.map((s) => [s.id, s.data.name]));

// 接通「籤詩↔神明」子圖：採用本籤系之神明（直連神明頁）。
const deitiesForSystem = (await deitiesBySystem()).get(d.system.id) ?? [];
// 前後籤導覽：同系統依籤序，避免籤頁成為孤點。
const sysPoems = (await poemsBySystem()).get(d.system.id) ?? [];
const curIdx = sysPoems.findIndex((p) => p.id === poem.id);
const prevPoem = curIdx > 0 ? sysPoems[curIdx - 1] : null;
const nextPoem = curIdx >= 0 && curIdx < sysPoems.length - 1 ? sysPoems[curIdx + 1] : null;
const poemLabel = (p: typeof poem) => `第 ${p.data.no} 籤${(p.data.ganzhi || p.data.title) ? ` · ${p.data.ganzhi ?? p.data.title}` : ''}`;

// 白話賞析（版面主角，§0.5）＝ interpretation md body；八項分項解 ＝ frontmatter（次級）
const ai = interp?.data ?? {};
const ASPECTS = ['運勢', '求財', '姻緣', '六甲', '功名', '訴訟', '疾病', '行人', '失物'] as const;
const interpVals = ai as Record<string, string | undefined>;
const hasAnyInterp = ASPECTS.some((a) => interpVals[a]);
const hasShangxi = interp ? (interp.body ?? '').trim().length > 0 : false;
const ShangxiContent = interp && hasShangxi ? (await render(interp)).Content : null;

// SEO：每頁唯一描述（四句＋卦頭典故＋系統）；GEO：CreativeWork＋BreadcrumbList
const label = d.ganzhi ?? d.title ?? '';
const sysName = systemName.get(d.system.id) ?? '';
const firstAllusionName = d.allusions[0] ? allusionName.get(d.allusions[0].ref.id) : '';
const firstAllusionNote = d.allusions[0]?.note ?? '';
const pageDesc =
  `${sysName}第 ${d.no} 籤${label ? `「${label}」` : ''}${d.fortune ? `（${d.fortune}）` : ''}：` +
  `${d.lines.join('，')}。` +
  `${firstAllusionName ? `卦頭典故「${firstAllusionName}」${firstAllusionNote ? `，${firstAllusionNote}` : ''}。` : ''}白話賞析與八項分項解。`;
const ld: object[] = [
  poemWork({ id: poem.id, no: d.no, label, systemName: sysName, lines: d.lines, fortune: d.fortune }),
  breadcrumb([
    { name: '籤詩', path: '/poems/' },
    { name: sysName, path: `/systems/${d.system.id}/` },
    { name: `第 ${d.no} 籤`, path: `/poems/${poem.id}/` },
  ]),
];

// answer-first 一行摘要（P1-5）：系統＋第N籤＋干支/題＋吉凶，可被引用為直接答案
const labelGloss = label ? `「${label}」` : '';
const leadAnswer =
  `${sysName}第 ${d.no} 籤${labelGloss}` +
  `${d.fortune ? `，吉凶為${d.fortune}` : ''}` +
  `${firstAllusionName ? `，卦頭典故出自「${firstAllusionName}」` : ''}。`;

// FAQPage（AEO，P1-4）：八項分項解即天然問答，逐項對映；空項略過。問題含系統＋第N籤＋label，利精準命中
const qlabel = `${sysName}第 ${d.no} 籤${labelGloss}`;
const ASPECT_Q: Record<(typeof ASPECTS)[number], string> = {
  運勢: `${qlabel}的運勢如何？`,
  求財: `${qlabel}求財順利嗎？`,
  姻緣: `${qlabel}的姻緣如何？`,
  六甲: `${qlabel}求子（六甲、生育）如何？`,
  功名: `${qlabel}的功名（考運）如何？`,
  訴訟: `${qlabel}的訴訟結果如何？`,
  疾病: `${qlabel}的疾病能否痊癒？`,
  行人: `${qlabel}問行人（出外的人）何時歸？`,
  失物: `${qlabel}的失物找得回嗎？`,
};
const faqItems = ASPECTS.filter((a) => interpVals[a]?.trim()).map((a) => ({
  q: ASPECT_Q[a],
  a: interpVals[a]!,
}));
const faq = faqPage(faqItems);
if (faq) ld.push(faq);
---

<Base
  title={`第 ${d.no} 籤${d.ganzhi ? ` ${d.ganzhi}` : d.title ? ` ${d.title}` : ''}`}
  description={pageDesc}
  jsonLd={ld}
  ogType="article"
  speakable={['h1', '.lead']}
>
  <nav class="crumb"><a href="/poems/">籤詩</a> ／ 第 {d.no} 籤</nav>

  <article class="poem-detail">
    <header class="ph">
      <h1>第 {d.no} 籤{(d.ganzhi || d.title) && ` · ${d.ganzhi ?? d.title}`}</h1>
      <div class="meta">
        <a class="tag" href={`/systems/${d.system.id}/`}>{systemName.get(d.system.id)}</a>
        {d.ganzhi && d.title && <span class="tag">{d.title}</span>}
        {d.gua && <span class="tag">{d.gua}卦</span>}
        {d.wuxing && <span class="tag">{d.wuxing.element}·{d.wuxing.season}·{d.wuxing.direction}</span>}
        {/* 吉凶輔標：小、次級；本系統多無原生定級（A.3-1） */}
        {d.fortune && <span class="tag fortune">{d.fortune}</span>}
      </div>
      {/* answer-first 一行摘要（P1-5）：可被引用為直接答案，仍保克制（小、次於四句主角） */}
      <p class="lead muted">{leadAnswer}</p>
    </header>

    {/* 主角：四句直書 */}
    <section class="lines-block">
      <div class="lines-zhi">
        {d.lines.map((l) => <p class="line">{l}</p>)}
      </div>
    </section>

    {/* 白話賞析（版面主角，§0.5）：緊扣四句意象與典故，文化呈現非算命 */}
    {
      ShangxiContent && (
        <section class="shangxi">
          <h2>白話賞析</h2>
          <div class="prose"><ShangxiContent /></div>
        </section>
      )
    }

    {/* 典故（諸說並陳，各掛源） */}
    <section>
      <h2>卦頭故事 · 典故</h2>
      {
        d.allusions.length === 0 ? (
          <p class="pending">本籤典故待補。</p>
        ) : (
          d.allusions.map((a) => {
            const node = allusionById.get(a.ref.id);
            return (
              <div class="card allusion">
                <p class="aname">
                  {node ? (
                    <a href={`/allusions/${a.ref.id}/`}>{node.data.name}</a>
                  ) : (
                    <span>{allusionName.get(a.ref.id) ?? a.ref.id}</span>
                  )}
                  {node?.data.source && <span class="muted">（{node.data.source}）</span>}
                </p>
                {a.note && <p class="muted small">記載：{a.note}</p>}
                {node && (node.body ?? '').trim().length > 0 ? (
                  <p class="muted small"><a href={`/allusions/${a.ref.id}/`}>讀白話故事與跨籤反查 →</a></p>
                ) : (
                  <p class="pending">白話故事撰寫中（公有領域題材，自行敘述後上架）。</p>
                )}
                {a.sources.length > 0 && (
                  <p class="src">來源：{a.sources.map((s) => s.ref).join('；')}</p>
                )}
              </div>
            );
          })
        )
      }
    </section>

    {/* 分項解（八項） */}
    <section>
      <h2>分項解</h2>
      {
        hasAnyInterp ? (
          <>
            <dl class="interp">
              {ASPECTS.map((a) => (
                <div class="row">
                  <dt>{a}</dt>
                  <dd>{interpVals[a] ?? <span class="pending">待撰</span>}</dd>
                </div>
              ))}
            </dl>
            <p class="src interp-src">
              分項解與白話賞析為<strong>本站原創撰寫</strong>，依公有領域題材、本籤四句與卦頭典故而作；
              非引現代解籤本。
            </p>
          </>
        ) : (
          <p class="pending">
            八項分項解（運勢／求財／姻緣／功名／訴訟／疾病／行人／失物）為本站原創撰寫，
            撰寫並標源後上架。現代解籤文字有著作權，本站不抄錄。
          </p>
        )
      }
    </section>

    {
      deitiesForSystem.length > 0 && (
        <section>
          <h2>採用此籤系之神明</h2>
          <ul class="deity-refs">
            {deitiesForSystem.map((dd) => (
              <li>
                <a href={`/deities/${dd.id}/`}>{dd.data.name}</a>
                <span class="muted small">　{dd.data.category}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {d.notes && (
      <section>
        <h2>校訂註記</h2>
        <p class="muted small">{d.notes}</p>
      </section>
    )}

    <nav class="poem-nav" aria-label="籤序導覽">
      {
        prevPoem ? (
          <a class="nav-btn" href={`/poems/${prevPoem.id}/`} rel="prev">‹ {poemLabel(prevPoem)}</a>
        ) : (
          <span class="nav-btn disabled">‹ 已是首籤</span>
        )
      }
      <a class="nav-btn" href={`/systems/${d.system.id}/`}>全部籤</a>
      {
        nextPoem ? (
          <a class="nav-btn" href={`/poems/${nextPoem.id}/`} rel="next">{poemLabel(nextPoem)} ›</a>
        ) : (
          <span class="nav-btn disabled">已是末籤 ›</span>
        )
      }
    </nav>

    <p class="src footer-src">{d.version_source}</p>
  </article>

  <style>
    .crumb { color: var(--ink-soft); font-size: 0.9rem; margin-bottom: 0.5rem; }
    .ph h1 { margin: 0.2rem 0 0.6rem; }
    .ph .meta { margin-bottom: 0.5rem; }
    .ph .lead { font-size: 0.92rem; margin: 0.2rem 0 0; }
    .lines-block { margin: 1.8rem 0 2.2rem; display: flex; justify-content: center; }
    /* 四句直書（直排・右起），§0.5 四句直書 */
    .lines-zhi {
      writing-mode: vertical-rl;
      text-orientation: upright;
      font-size: 1.55rem;
      letter-spacing: 0.18em;
      line-height: 2.1;
      max-height: 18rem;
      display: flex;
      gap: 0.2rem;
    }
    .lines-zhi .line { margin: 0; }
    @media (max-width: 34rem) {
      .lines-zhi { font-size: 1.3rem; max-height: 15rem; }
    }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-top: 2rem; }
    .allusion .aname { font-weight: 700; margin: 0 0 0.3rem; }
    .small { font-size: 0.88rem; }
    .src { color: var(--gold); font-size: 0.82rem; }
    .interp { margin: 0.5rem 0; }
    .interp .row { display: grid; grid-template-columns: 4rem 1fr; gap: 0.5rem; padding: 0.35rem 0; border-bottom: 1px dashed var(--line); }
    .interp dt { font-weight: 700; color: var(--accent); }
    .interp dd { margin: 0; }
    .deity-refs { list-style: none; padding: 0; }
    .deity-refs li { padding: 0.3rem 0; }
    .poem-nav { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin-top: 2rem; }
    .poem-nav .nav-btn {
      padding: 0.3rem 0.8rem; border: 1px solid var(--line); border-radius: 0.4rem;
      background: var(--paper-2); color: var(--ink); font-size: var(--text-sm);
    }
    .poem-nav .nav-btn:hover { text-decoration: none; border-color: var(--accent-soft); }
    .poem-nav .nav-btn.disabled { color: var(--ink-soft); opacity: 0.45; pointer-events: none; }
    .footer-src { margin-top: 2rem; }
  </style>
</Base>
