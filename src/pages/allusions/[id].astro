---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getAllusions, poemsByAllusion } from '../../lib/queries';
import { breadcrumb, faqPage } from '../../lib/seo';

export const getStaticPaths = (async () => {
  const allusions = await getAllusions();
  const index = await poemsByAllusion();
  return allusions.map((a) => ({
    params: { id: a.id },
    props: { allusion: a, poems: (index.get(a.id) ?? []).sort((x, y) => x.data.no - y.data.no) },
  }));
}) satisfies GetStaticPaths;

const { allusion, poems } = Astro.props;
const a = allusion.data;
// 白話故事為 md body（公有領域題材自行敘述，§6）；空 body → 待撰
const hasStory = (allusion.body ?? '').trim().length > 0;
const { Content } = await render(allusion);
const pageDesc =
  a.seoDesc ??
  (`${a.name}${a.source ? `（出典：${a.source}）` : ''}${a.people.length ? `，關聯人物：${a.people.join('、')}` : ''}。` +
  `${poems.length ? `出現於第 ${poems.map((p) => p.data.no).join('、')} 籤（跨文本反查）。` : ''}`);

// GEO：BreadcrumbList ＋（有白話故事時）FAQPage（AEO，P1-4）。故事首句作為「故事是什麼」之答案，不杜撰
const ld: object[] = [
  breadcrumb([
    { name: '籤詩', path: '/poems/' },
    { name: '典故', path: '/allusions/' },
    { name: a.name, path: `/allusions/${allusion.id}/` },
  ]),
];
if (hasStory) {
  const storySummary = (allusion.body ?? '').trim().split(/(?<=[。！？])/)[0]?.trim() ?? '';
  const faq = faqPage([{ q: `「${a.name}」的故事是什麼？`, a: storySummary }]);
  if (faq) ld.push(faq);
}
---

<Base
  title={`典故 · ${a.name}`}
  description={pageDesc}
  jsonLd={ld}
  ogType="article"
  speakable={['h1', '.story']}
>
  <nav class="crumb"><a href="/poems/">籤詩</a> ／ <a href="/allusions/">典故</a> ／ {a.name}</nav>
  <h1>{a.name}</h1>
  {a.source && <p class="muted">出典：{a.source}</p>}
  {a.people.length > 0 && (
    <p>關聯人物：{a.people.map((p) => <span class="tag">{p}</span>)}</p>
  )}

  {
    hasStory ? (
      <div class="story prose"><Content /></div>
    ) : (
      <p class="pending">白話故事撰寫中（公有領域題材，自行敘述後上架；不抄特定改寫本）。</p>
    )
  }

  <section>
    <h2>出現於哪些籤 · 跨文本追蹤</h2>
    <p class="muted small">同一典故橫跨多支籤者，正是跨文本追蹤的價值點（去重節點）。</p>
    {
      poems.length === 0 ? (
        <p class="pending">尚無已發佈籤詩關聯此典故。</p>
      ) : (
        <ul class="poem-refs">
          {poems.map((p) => (
            <li>
              <a href={`/poems/${p.id}/`}>第 {p.data.no} 籤 · {p.data.ganzhi}</a>
              <span class="muted">　{p.data.lines[0]}…</span>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <style>
    .crumb { color: var(--ink-soft); font-size: var(--text-sm); margin-bottom: 0.625rem; }
    .story { margin: 1.25rem 0; }
    .small { font-size: var(--text-sm); }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.375rem; }
    .poem-refs { list-style: none; padding: 0; }
    .poem-refs li { padding: 0.5rem 0; border-bottom: 1px dashed var(--line); }
  </style>
</Base>
