---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import { getDeities, getSystems, relationsOf, templesByDeity, poemsBySystem, practicesByDeity, eventsByDeity, tradesByDeity } from '../../lib/queries';
import { breadcrumb, deityThing, faqPage } from '../../lib/seo';

export const getStaticPaths = (async () => {
  const deities = await getDeities();
  const nameById = new Map(deities.map((d) => [d.id, d.data.name]));
  const tByDeity = await templesByDeity();
  return Promise.all(
    deities.map(async (d) => ({
      params: { id: d.id },
      props: { deity: d, rels: await relationsOf(d.id), nameById, temples: tByDeity.get(d.id) ?? [] },
    })),
  );
}) satisfies GetStaticPaths;

const { deity, rels, nameById, temples } = Astro.props;
const d = deity.data;
const systems = await getSystems();
const systemName = new Map(systems.map((s) => [s.id, s.data.name]));

// 接通「神明↔籤詩」子圖：本神採用之系統的全部籤（直連籤，避免子圖斷開）。
const poemsBySys = await poemsBySystem();
const relatedPoems = d.divination_systems.flatMap((s) => poemsBySys.get(s.id) ?? []);
// 反向：對應拜拜習俗（M5）、以本神為主神之民俗活動（M4）、守護行業（trades 反連）。
const relatedPractices = (await practicesByDeity()).get(deity.id) ?? [];
const relatedEvents = (await eventsByDeity()).get(deity.id) ?? [];
const relatedTrades = (await tradesByDeity()).get(deity.id) ?? [];

const label = (id: string) => nameById.get(id) ?? id; // 未成節點則顯示原字串（佔位）
const isNode = (id: string) => nameById.has(id);

// FAQPage（AEO，P1-4）：僅就既有資料生成，無源不杜撰（§5）。
const faqItems: { q: string; a: string }[] = [];

// 聖誕（農曆）：排除「無定／待查」等非實際日期者。
const realBdays = d.birthday_lunar.filter(
  (b) => b.date && !['無定', '待查', '未定'].includes(b.date),
);
if (realBdays.length > 0) {
  const parts = realBdays.map((b) => `農曆${b.date}（${b.kind}）`).join('、');
  faqItems.push({
    q: `${d.name}的聖誕（生日）是哪一天？`,
    a: `${d.name}的聖誕日為${parts}。`,
  });
}
const birthdayLabel = (() => {
  if (realBdays.length === 0) return '';
  const [bm, bd] = realBdays[0].date.split('-').map(Number);
  return `，${realBdays[0].kind}農曆${bm}月${bd}日`;
})();
// 標題也帶出聖誕日期關鍵字：反思層 2026-07-05 發現，聖誕/生日查詢（如「七爺八爺聖誕」）排名到位卻
// 連 5+ 天 0 點擊，因日期只進了 .summary、title 從未帶「聖誕」字樣。優先取「聖誕」該筆，
// 純沿用已查證的 birthday_lunar（不新增事實）。
const titleBday = (() => {
  const b = realBdays.find((x) => x.kind === '聖誕') ?? realBdays[0];
  if (!b) return '';
  const [bm, bd] = b.date.split('-').map(Number);
  return `・${b.kind}農曆${bm}月${bd}日`;
})();

// 職司／是什麼神：以 category＋office＋summary 答覆（answer-first）。
{
  const officePart = d.office.length ? `主要職司為${d.office.join('、')}` : '';
  const segs = [
    `${d.name}屬${d.category}`,
    officePart,
  ].filter(Boolean);
  let a = segs.join('，') + '。';
  if (d.summary) a += d.summary;
  if (officePart || d.summary) {
    faqItems.push({ q: `${d.name}是什麼神？職司是什麼？`, a });
  }
}

// 別名／封號。
if (d.aliases.length > 0) {
  faqItems.push({
    q: `${d.name}有哪些別名或封號？`,
    a: `${d.name}的別名與封號包括：${d.aliases.join('、')}。`,
  });
}

// 信仰類別（is_category）底下的具名實例。
if (d.is_category && d.instances.length > 0) {
  const names = d.instances.map((id) => label(id)).join('、');
  faqItems.push({
    q: `${d.name}底下有哪些具名神明？`,
    a: `${d.name}為信仰類別，底下具名神明包括：${names}。`,
  });
}

const faq = faqPage(faqItems);
const jsonLd = [
  deityThing({
    id: deity.id,
    name: d.name,
    aliases: d.aliases,
    category: d.category,
    office: d.office,
    summary: d.summary,
    sameAs: d.sameAs,
  }),
  breadcrumb([
    { name: '神明圖譜', path: '/deities' },
    { name: d.name, path: `/deities/${deity.id}` },
  ]),
  ...(faq ? [faq] : []),
];
---

<Base
  title={`${d.aliases.length > 0 && d.aliases[0] !== d.name ? `${d.name}（${d.aliases[0]}）` : d.name}${titleBday}`}
  description={`${d.name}${d.aliases.length ? `（${d.aliases.join('·')}）` : ''}—${d.category}${birthdayLabel}。${d.summary ?? `職司：${d.office.join('·')}`}`}
  ogType="article"
  jsonLd={jsonLd}
  speakable={['h1', '.summary']}
>
  <nav class="crumb"><a href="/deities">神明圖譜</a> ／ {d.category}</nav>

  <header class="dh">
    <h1>{d.name}</h1>
    <p class="aliases">
      <a class="tag" href="/deities">{d.category}</a>
      {d.is_category && <span class="tag">信仰類別（非單神）</span>}
      {d.groups.map((g) => <span class="tag">{g}</span>)}
    </p>
    {d.aliases.length > 0 && <p class="muted">別名／封號：{d.aliases.join('、')}</p>}
  </header>

  {d.summary && <p class="summary">{d.summary}</p>}

  <div class="cols2">
    <section>
      <h2>職司</h2>
      {d.office.length ? <p>{d.office.map((o) => <span class="tag">{o}</span>)}</p> : <p class="pending">待補</p>}
    </section>

    <section>
      <h2>聖誕（農曆）</h2>
      {
        d.birthday_lunar.length === 0 ? (
          <p class="pending">聖誕待查（無源不顯示）。</p>
        ) : (
          <ul class="bdays">
            {d.birthday_lunar.map((b) => (
              <li>
                <strong>{b.date}</strong> <span class="muted">{b.kind}</span>
                {b.note && <span class="muted small">　{b.note}</span>}
                {b.sources.length > 0 && <div class="src">{b.sources.map((s) => s.ref).join('；')}</div>}
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </div>

  {
    d.is_category && (
      <section>
        <h2>具名實例</h2>
        <p class="muted small">
          「{d.name}」為信仰類別；底下具名實例各有聖誕與廟宇對應（依實例而非類別）。
        </p>
        {d.instances.length > 0 ? (
          <ul class="rels">
            {d.instances.map((id) => (
              <li>
                {isNode(id) ? <a href={`/deities/${id}`}>{label(id)}</a> : <span>{label(id)}</span>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="pending">具名實例節點建置中。</p>
        )}
      </section>
    )
  }

  <section>
    <h2>採用之籤詩系統</h2>
    {
      d.divination_systems.length ? (
        <ul>
          {d.divination_systems.map((s) => (
            <li><a href={`/systems/${s.id}`}>{systemName.get(s.id) ?? s.id}</a></li>
          ))}
        </ul>
      ) : (
        <p class="muted">尚未標註常用籤詩系統。</p>
      )
    }
  </section>

  {
    relatedPoems.length > 0 && (
      <section>
        <h2>相關籤詩</h2>
        {d.divination_systems.map((s) => {
          const list = poemsBySys.get(s.id) ?? [];
          if (!list.length) return null;
          return (
            <div class="poem-group">
              <p class="muted small">
                <a href={`/systems/${s.id}`}>{systemName.get(s.id) ?? s.id}</a>　共 {list.length} 籤
              </p>
              <ul class="poem-links">
                {list.slice(0, 12).map((p) => (
                  <li>
                    <a href={`/poems/${p.id}`}>第 {p.data.no} 籤{(p.data.ganzhi || p.data.title) && ` · ${p.data.ganzhi ?? p.data.title}`}</a>
                  </li>
                ))}
              </ul>
              {list.length > 12 && <p class="muted small"><a href={`/systems/${s.id}`}>看全部 {list.length} 籤 →</a></p>}
            </div>
          );
        })}
      </section>
    )
  }

  <section>
    <h2>關係網</h2>
    {
      rels.out.length === 0 && rels.in.length === 0 ? (
        <p class="muted">尚無已發佈關係邊。</p>
      ) : (
        <ul class="rels">
          {rels.out.map((r) => (
            <li>
              {d.name} <span class="reltype">— {r.data.type} →</span>{' '}
              {isNode(r.data.to) ? <a href={`/deities/${r.data.to}`}>{label(r.data.to)}</a> : <span class="placeholder">{label(r.data.to)}<span class="tag">待建</span></span>}
              {r.data.note && <span class="muted small">　{r.data.note}</span>}
            </li>
          ))}
          {rels.in.map((r) => (
            <li>
              {isNode(r.data.from) ? <a href={`/deities/${r.data.from}`}>{label(r.data.from)}</a> : <span class="placeholder">{label(r.data.from)}</span>}{' '}
              <span class="reltype">— {r.data.type} →</span> {d.name}
              {r.data.note && <span class="muted small">　{r.data.note}</span>}
            </li>
          ))}
        </ul>
      )
    }
    <p class="muted small">v1 關係以列表呈現；圖視覺化列發佈後增補。</p>
  </section>

  {
    temples.length > 0 && (
      <section>
        <h2>主祀此神之廟宇{temples.length > 30 && <span class="muted small">　共 {temples.length} 間，列出 30 間</span>}</h2>
        <ul>
          {temples.slice(0, 30).map((t) => (
            <li>
              <a href={`/temples/${t.id}`}>{t.data.name}</a>
              {t.data.district && <span class="muted small">　{t.data.district}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    relatedTrades.length > 0 && (
      <p class="muted">
        守護行業：
        {relatedTrades.map((t, i) => (
          <>
            {i > 0 && '、'}
            <a href={`/trades/${t.id}`}>{t.data.name}</a>
          </>
        ))}
      </p>
    )
  }

  {
    relatedPractices.length > 0 && (
      <section>
        <h2>相關拜拜習俗</h2>
        <ul class="rels">
          {relatedPractices.map((p) => (
            <li>
              <a href={`/practices/${p.id}`}>{p.data.title}</a>
              {p.data.summary && <span class="muted small">　{p.data.summary}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    relatedEvents.length > 0 && (
      <section>
        <h2>相關民俗活動</h2>
        <ul class="rels">
          {relatedEvents.map((e) => (
            <li>
              <a href={`/events/${e.id}`}>{e.data.name}</a>
              {e.data.region.length > 0 && <span class="muted small">　{e.data.region.join('、')}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {d.sources.length > 0 && <p class="src footer-src">來源：{d.sources.map((s) => s.ref).join('；')}</p>}

  <style>
    .crumb { color: var(--ink-soft); font-size: 0.9rem; margin-bottom: 0.5rem; }
    .dh h1 { margin: 0.2rem 0 0.4rem; }
    .summary { font-size: 1.05rem; }
    .cols2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 2rem; }
    @media (max-width: 40rem) { .cols2 { grid-template-columns: 1fr; } }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-top: 1.6rem; }
    .bdays { list-style: none; padding: 0; }
    .bdays li { padding: 0.3rem 0; }
    .src { color: var(--gold); font-size: 0.82rem; }
    .small { font-size: 0.85rem; }
    .rels { list-style: none; padding: 0; }
    .rels li { padding: 0.35rem 0; border-bottom: 1px dashed var(--line); }
    .reltype { color: var(--accent); font-size: 0.9rem; }
    .placeholder { color: var(--ink-soft); }
    .poem-group { margin: 0.6rem 0 1rem; }
    .poem-links { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr)); gap: 0.1rem 1rem; }
    .poem-links li { padding: 0.2rem 0; }
    .footer-src { margin-top: 2rem; }
    .note { margin: 1rem 0; }
  </style>
</Base>
