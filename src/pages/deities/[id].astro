---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import { getDeities, getSystems, relationsOf, templesByDeity, poemsBySystem, practicesByDeity, eventsByDeity, tradesByDeity } from '../../lib/queries';
import { breadcrumb, deityThing, faqPage } from '../../lib/seo';

export const getStaticPaths = (async () => {
  const deities = await getDeities();
  const nameById = new Map(deities.map((d) => [d.id, d.data.name]));
  const tByDeity = await templesByDeity();
  return Promise.all(
    deities.map(async (d) => ({
      params: { id: d.id },
      props: { deity: d, rels: await relationsOf(d.id), nameById, temples: tByDeity.get(d.id) ?? [] },
    })),
  );
}) satisfies GetStaticPaths;

const { deity, rels, nameById, temples } = Astro.props;
const d = deity.data;
const systems = await getSystems();
const systemName = new Map(systems.map((s) => [s.id, s.data.name]));

// жҺҘйҖҡгҖҢзҘһжҳҺвҶ”зұӨи©©гҖҚеӯҗең–пјҡжң¬зҘһжҺЎз”Ёд№Ӣзі»зөұзҡ„е…ЁйғЁзұӨпјҲзӣҙйҖЈзұӨпјҢйҒҝе…Қеӯҗең–ж–·й–ӢпјүгҖӮ
const poemsBySys = await poemsBySystem();
const relatedPoems = d.divination_systems.flatMap((s) => poemsBySys.get(s.id) ?? []);
// еҸҚеҗ‘пјҡе°ҚжҮүжӢңжӢңзҝ’дҝ—пјҲM5пјүгҖҒд»Ҙжң¬зҘһзӮәдё»зҘһд№Ӣж°‘дҝ—жҙ»еӢ•пјҲM4пјүгҖҒе®Ҳиӯ·иЎҢжҘӯпјҲtrades еҸҚйҖЈпјүгҖӮ
const relatedPractices = (await practicesByDeity()).get(deity.id) ?? [];
const relatedEvents = (await eventsByDeity()).get(deity.id) ?? [];
const relatedTrades = (await tradesByDeity()).get(deity.id) ?? [];

const label = (id: string) => nameById.get(id) ?? id; // жңӘжҲҗзҜҖй»һеүҮйЎҜзӨәеҺҹеӯ—дёІпјҲдҪ”дҪҚпјү
const isNode = (id: string) => nameById.has(id);

// FAQPageпјҲAEOпјҢP1-4пјүпјҡеғ…е°ұж—ўжңүиіҮж–ҷз”ҹжҲҗпјҢз„ЎжәҗдёҚжқңж’°пјҲВ§5пјүгҖӮ
const faqItems: { q: string; a: string }[] = [];

// иҒ–иӘ•пјҲиҫІжӣҶпјүпјҡжҺ’йҷӨгҖҢз„Ўе®ҡпјҸеҫ…жҹҘгҖҚзӯүйқһеҜҰйҡӣж—ҘжңҹиҖ…гҖӮ
const realBdays = d.birthday_lunar.filter(
  (b) => b.date && !['з„Ўе®ҡ', 'еҫ…жҹҘ', 'жңӘе®ҡ'].includes(b.date),
);
if (realBdays.length > 0) {
  const parts = realBdays.map((b) => `иҫІжӣҶ${b.date}пјҲ${b.kind}пјү`).join('гҖҒ');
  faqItems.push({
    q: `${d.name}зҡ„иҒ–иӘ•пјҲз”ҹж—ҘпјүжҳҜе“ӘдёҖеӨ©пјҹ`,
    a: `${d.name}зҡ„иҒ–иӘ•ж—ҘзӮә${parts}гҖӮ`,
  });
}
const birthdayLabel = (() => {
  if (realBdays.length === 0) return '';
  const [bm, bd] = realBdays[0].date.split('-').map(Number);
  return `пјҢ${realBdays[0].kind}иҫІжӣҶ${bm}жңҲ${bd}ж—Ҙ`;
})();

// иҒ·еҸёпјҸжҳҜд»ҖйәјзҘһпјҡд»Ҙ categoryпјӢofficeпјӢsummary зӯ”иҰҶпјҲanswer-firstпјүгҖӮ
{
  const officePart = d.office.length ? `дё»иҰҒиҒ·еҸёзӮә${d.office.join('гҖҒ')}` : '';
  const segs = [
    `${d.name}еұ¬${d.category}`,
    officePart,
  ].filter(Boolean);
  let a = segs.join('пјҢ') + 'гҖӮ';
  if (d.summary) a += d.summary;
  if (officePart || d.summary) {
    faqItems.push({ q: `${d.name}жҳҜд»ҖйәјзҘһпјҹиҒ·еҸёжҳҜд»Җйәјпјҹ`, a });
  }
}

// еҲҘеҗҚпјҸе°ҒиҷҹгҖӮ
if (d.aliases.length > 0) {
  faqItems.push({
    q: `${d.name}жңүе“ӘдәӣеҲҘеҗҚжҲ–е°Ғиҷҹпјҹ`,
    a: `${d.name}зҡ„еҲҘеҗҚиҲҮе°ҒиҷҹеҢ…жӢ¬пјҡ${d.aliases.join('гҖҒ')}гҖӮ`,
  });
}

// дҝЎд»°йЎһеҲҘпјҲis_categoryпјүеә•дёӢзҡ„е…·еҗҚеҜҰдҫӢгҖӮ
if (d.is_category && d.instances.length > 0) {
  const names = d.instances.map((id) => label(id)).join('гҖҒ');
  faqItems.push({
    q: `${d.name}еә•дёӢжңүе“Әдәӣе…·еҗҚзҘһжҳҺпјҹ`,
    a: `${d.name}зӮәдҝЎд»°йЎһеҲҘпјҢеә•дёӢе…·еҗҚзҘһжҳҺеҢ…жӢ¬пјҡ${names}гҖӮ`,
  });
}

const faq = faqPage(faqItems);
const jsonLd = [
  deityThing({
    id: deity.id,
    name: d.name,
    aliases: d.aliases,
    category: d.category,
    office: d.office,
    summary: d.summary,
    sameAs: d.sameAs,
  }),
  breadcrumb([
    { name: 'зҘһжҳҺең–иӯң', path: '/deities' },
    { name: d.name, path: `/deities/${deity.id}` },
  ]),
  ...(faq ? [faq] : []),
];
---

<Base
  title={d.aliases.length > 0 && d.aliases[0] !== d.name ? `${d.name}пјҲ${d.aliases[0]}пјү` : d.name}
  description={`${d.name}${d.aliases.length ? `пјҲ${d.aliases.join('В·')}пјү` : ''}вҖ”${d.category}${birthdayLabel}гҖӮ${d.summary ?? `иҒ·еҸёпјҡ${d.office.join('В·')}`}`}
  ogType="article"
  jsonLd={jsonLd}
  speakable={['h1', '.summary']}
>
  <nav class="crumb"><a href="/deities">зҘһжҳҺең–иӯң</a> пјҸ {d.category}</nav>

  <header class="dh">
    <h1>{d.name}</h1>
    <p class="aliases">
      <a class="tag" href="/deities">{d.category}</a>
      {d.is_category && <span class="tag">дҝЎд»°йЎһеҲҘпјҲйқһе–®зҘһпјү</span>}
      {d.groups.map((g) => <span class="tag">{g}</span>)}
    </p>
    {d.aliases.length > 0 && <p class="muted">еҲҘеҗҚпјҸе°Ғиҷҹпјҡ{d.aliases.join('гҖҒ')}</p>}
  </header>

  {d.summary && <p class="summary">{d.summary}</p>}

  <div class="cols2">
    <section>
      <h2>иҒ·еҸё</h2>
      {d.office.length ? <p>{d.office.map((o) => <span class="tag">{o}</span>)}</p> : <p class="pending">еҫ…иЈң</p>}
    </section>

    <section>
      <h2>иҒ–иӘ•пјҲиҫІжӣҶпјү</h2>
      {
        d.birthday_lunar.length === 0 ? (
          <p class="pending">иҒ–иӘ•еҫ…жҹҘпјҲз„ЎжәҗдёҚйЎҜзӨәпјҢВ§5пјүгҖӮ</p>
        ) : (
          <ul class="bdays">
            {d.birthday_lunar.map((b) => (
              <li>
                <strong>{b.date}</strong> <span class="muted">{b.kind}</span>
                {b.note && <span class="muted small">гҖҖ{b.note}</span>}
                {b.sources.length > 0 && <div class="src">{b.sources.map((s) => s.ref).join('пјӣ')}</div>}
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </div>

  {
    d.is_category && (
      <section>
        <h2>е…·еҗҚеҜҰдҫӢ</h2>
        <p class="muted small">
          гҖҢ{d.name}гҖҚзӮәдҝЎд»°йЎһеҲҘпјӣеә•дёӢе…·еҗҚеҜҰдҫӢеҗ„жңүиҒ–иӘ•иҲҮе»ҹе®Үе°ҚжҮүпјҲдҫқеҜҰдҫӢиҖҢйқһйЎһеҲҘпјҢB.3-1пјүгҖӮ
        </p>
        {d.instances.length > 0 ? (
          <ul class="rels">
            {d.instances.map((id) => (
              <li>
                {isNode(id) ? <a href={`/deities/${id}`}>{label(id)}</a> : <span>{label(id)}</span>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="pending">е…·еҗҚеҜҰдҫӢзҜҖй»һе»әзҪ®дёӯгҖӮ</p>
        )}
      </section>
    )
  }

  <section>
    <h2>жҺЎз”Ёд№ӢзұӨи©©зі»зөұ</h2>
    {
      d.divination_systems.length ? (
        <ul>
          {d.divination_systems.map((s) => (
            <li><a href={`/systems/${s.id}`}>{systemName.get(s.id) ?? s.id}</a></li>
          ))}
        </ul>
      ) : (
        <p class="muted">е°ҡжңӘжЁҷиЁ»еёёз”ЁзұӨи©©зі»зөұгҖӮ</p>
      )
    }
  </section>

  {
    relatedPoems.length > 0 && (
      <section>
        <h2>зӣёй—ңзұӨи©©</h2>
        {d.divination_systems.map((s) => {
          const list = poemsBySys.get(s.id) ?? [];
          if (!list.length) return null;
          return (
            <div class="poem-group">
              <p class="muted small">
                <a href={`/systems/${s.id}`}>{systemName.get(s.id) ?? s.id}</a>гҖҖе…ұ {list.length} зұӨ
              </p>
              <ul class="poem-links">
                {list.slice(0, 12).map((p) => (
                  <li>
                    <a href={`/poems/${p.id}`}>з¬¬ {p.data.no} зұӨ{(p.data.ganzhi || p.data.title) && ` В· ${p.data.ganzhi ?? p.data.title}`}</a>
                  </li>
                ))}
              </ul>
              {list.length > 12 && <p class="muted small"><a href={`/systems/${s.id}`}>зңӢе…ЁйғЁ {list.length} зұӨ вҶ’</a></p>}
            </div>
          );
        })}
      </section>
    )
  }

  <section>
    <h2>й—ңдҝӮз¶І</h2>
    {
      rels.out.length === 0 && rels.in.length === 0 ? (
        <p class="muted">е°ҡз„Ўе·ІзҷјдҪҲй—ңдҝӮйӮҠгҖӮ</p>
      ) : (
        <ul class="rels">
          {rels.out.map((r) => (
            <li>
              {d.name} <span class="reltype">вҖ” {r.data.type} вҶ’</span>{' '}
              {isNode(r.data.to) ? <a href={`/deities/${r.data.to}`}>{label(r.data.to)}</a> : <span class="placeholder">{label(r.data.to)}<span class="tag">еҫ…е»ә</span></span>}
              {r.data.note && <span class="muted small">гҖҖ{r.data.note}</span>}
            </li>
          ))}
          {rels.in.map((r) => (
            <li>
              {isNode(r.data.from) ? <a href={`/deities/${r.data.from}`}>{label(r.data.from)}</a> : <span class="placeholder">{label(r.data.from)}</span>}{' '}
              <span class="reltype">вҖ” {r.data.type} вҶ’</span> {d.name}
              {r.data.note && <span class="muted small">гҖҖ{r.data.note}</span>}
            </li>
          ))}
        </ul>
      )
    }
    <p class="muted small">v1 й—ңдҝӮд»ҘеҲ—иЎЁе‘ҲзҸҫпјӣең–иҰ–иҰәеҢ–еҲ—зҷјдҪҲеҫҢеўһиЈңпјҲВ§8пјүгҖӮ</p>
  </section>

  {
    temples.length > 0 && (
      <section>
        <h2>дё»зҘҖжӯӨзҘһд№Ӣе»ҹе®Ү{temples.length > 30 && <span class="muted small">гҖҖе…ұ {temples.length} й–“пјҢеҲ—еҮә 30 й–“</span>}</h2>
        <ul>
          {temples.slice(0, 30).map((t) => (
            <li>
              <a href={`/temples/${t.id}`}>{t.data.name}</a>
              {t.data.district && <span class="muted small">гҖҖ{t.data.district}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    relatedTrades.length > 0 && (
      <p class="muted">
        е®Ҳиӯ·иЎҢжҘӯпјҡ
        {relatedTrades.map((t, i) => (
          <>
            {i > 0 && 'гҖҒ'}
            <a href={`/trades/${t.id}`}>{t.data.name}</a>
          </>
        ))}
      </p>
    )
  }

  {
    relatedPractices.length > 0 && (
      <section>
        <h2>зӣёй—ңжӢңжӢңзҝ’дҝ—</h2>
        <ul class="rels">
          {relatedPractices.map((p) => (
            <li>
              <a href={`/practices/${p.id}`}>{p.data.title}</a>
              {p.data.summary && <span class="muted small">гҖҖ{p.data.summary}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    relatedEvents.length > 0 && (
      <section>
        <h2>зӣёй—ңж°‘дҝ—жҙ»еӢ•</h2>
        <ul class="rels">
          {relatedEvents.map((e) => (
            <li>
              <a href={`/events/${e.id}`}>{e.data.name}</a>
              {e.data.region.length > 0 && <span class="muted small">гҖҖ{e.data.region.join('гҖҒ')}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {d.sources.length > 0 && <p class="src footer-src">дҫҶжәҗпјҡ{d.sources.map((s) => s.ref).join('пјӣ')}</p>}

  <style>
    .crumb { color: var(--ink-soft); font-size: 0.9rem; margin-bottom: 0.5rem; }
    .dh h1 { margin: 0.2rem 0 0.4rem; }
    .summary { font-size: 1.05rem; }
    .cols2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 2rem; }
    @media (max-width: 40rem) { .cols2 { grid-template-columns: 1fr; } }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-top: 1.6rem; }
    .bdays { list-style: none; padding: 0; }
    .bdays li { padding: 0.3rem 0; }
    .src { color: var(--gold); font-size: 0.82rem; }
    .small { font-size: 0.85rem; }
    .rels { list-style: none; padding: 0; }
    .rels li { padding: 0.35rem 0; border-bottom: 1px dashed var(--line); }
    .reltype { color: var(--accent); font-size: 0.9rem; }
    .placeholder { color: var(--ink-soft); }
    .poem-group { margin: 0.6rem 0 1rem; }
    .poem-links { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr)); gap: 0.1rem 1rem; }
    .poem-links li { padding: 0.2rem 0; }
    .footer-src { margin-top: 2rem; }
    .note { margin: 1rem 0; }
  </style>
</Base>
