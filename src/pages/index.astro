---
import Base from '../layouts/Base.astro';
import { getPoems, getAllusions } from '../lib/queries';
import { todayInTaipei, pickDailyIndex } from '../lib/daily';

// 今日中樞（§0.5）：每日一籤領銜（情感主角），模組入口平等可達。
// 不把運勢吉凶當頭條；吉凶若有也僅作輔標（本系統籤詩多無吉凶定級）。
// 每日一籤固定取六十甲子籤（旗艦系統），維持「今日選讀」策展的一致性（§0.5）
const poems = (await getPoems())
  .filter((p) => p.data.system.id === 'liushi_jiazi')
  .sort((a, b) => a.data.no - b.data.no);
const allusions = await getAllusions();
const allusionById = new Map(allusions.map((a) => [a.id, a]));

const { iso, epochDay } = todayInTaipei();
const idx = pickDailyIndex(epochDay, poems.length);
const todayPoem = poems[idx];
const firstAllusion = todayPoem?.data.allusions[0];
const allusion = firstAllusion ? allusionById.get(firstAllusion.ref.id) : undefined;

const modules = [
  { href: '/poems', label: '籤詩解碼', desc: '六十甲子籤，四句＋典故＋分項解' },
  { href: '/deities', label: '神明圖譜', desc: '七大類、職司、聖誕、關係網' },
  { href: '/almanac', label: '農民曆', desc: '干支建除、宜忌考據化（建置中）' },
  { href: '/events', label: '民俗活動', desc: '遶境進香、文資身分' },
  { href: '/practices', label: '拜拜習俗', desc: '科儀步驟、金紙供品' },
];
---

<Base description="台灣民俗信仰考據：籤詩解碼與神明圖譜，逐條掛來源、諸說並陳。">
  <section class="hero">
    <p class="kicker">今日選讀 · {iso}（全站同一支）</p>
    {
      todayPoem && (
        <article class="daily card">
          <header class="daily-head">
            <h1>
              <a href={`/poems/${todayPoem.id}`}>
                第 {todayPoem.data.no} 籤 · {todayPoem.data.ganzhi}
              </a>
            </h1>
            <span class="gua">{todayPoem.data.gua && `${todayPoem.data.gua}卦`}</span>
          </header>
          <p class="lines-vertical daily-lines">
            {todayPoem.data.lines.map((l) => <span class="line">{l}</span>)}
          </p>
          {allusion && (
            <p class="allusion-hint">
              卦頭故事：<a href={`/allusions/${allusion.id}`}>{allusion.data.name}</a>
              {allusion.data.source && <span class="muted">（{allusion.data.source}）</span>}
            </p>
          )}
          <p class="daily-cta">
            <a href={`/poems/${todayPoem.id}`}>讀解碼：四句賞析 · 典故 · 分項解 →</a>
          </p>
        </article>
      )
    }
    <p class="note muted">
      每日一籤為策展（像每日一詩），同日全站一致、不因人隨機、不標個人運勢。亦可
      <a href="/poems">自由瀏覽全部籤詩 →</a>
    </p>
  </section>

  <section class="modules">
    <h2>由此深掘</h2>
    <div class="grid cols">
      {
        modules.map((m) => (
          <a class="module card" href={m.href}>
            <strong>{m.label}</strong>
            <span class="muted">{m.desc}</span>
          </a>
        ))
      }
    </div>
  </section>

  <style>
    .kicker { color: var(--gold); letter-spacing: 0.1em; font-size: 0.9rem; margin: 0 0 0.5rem; }
    .daily { border-color: var(--accent-soft); }
    .daily-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
    .daily-head h1 { margin: 0; font-size: 1.5rem; }
    .daily-head h1 a { color: var(--ink); }
    .gua { color: var(--accent); font-weight: 700; }
    .daily-lines { margin: 1.2rem 0; }
    .daily-lines .line { display: block; }
    .allusion-hint { margin: 0.6rem 0 0.2rem; }
    .daily-cta { margin: 0.8rem 0 0; font-weight: 700; }
    .note { font-size: 0.9rem; margin-top: 1rem; }
    .modules { margin-top: 2.5rem; }
    .module { display: flex; flex-direction: column; gap: 0.25rem; }
    .module strong { color: var(--ink); }
  </style>
</Base>
