---
import Base from '../layouts/Base.astro';
import { getPoems, getAllusions } from '../lib/queries';
import { todayInTaipei, pickDailyIndex } from '../lib/daily';

// 今日中樞（§0.5）：每日一籤領銜（情感主角），模組入口平等可達。
// 不把運勢吉凶當頭條；吉凶若有也僅作輔標（本系統籤詩多無吉凶定級）。
// 每日一籤固定取六十甲子籤（旗艦系統），維持「今日選讀」策展的一致性（§0.5）
const poems = (await getPoems())
  .filter((p) => p.data.system.id === 'liushi_jiazi')
  .sort((a, b) => a.data.no - b.data.no);
const allPoemIds = (await getPoems()).map((p) => p.id); // 擲一支隨機瀏覽用（§0.5）
const allusions = await getAllusions();
const allusionById = new Map(allusions.map((a) => [a.id, a]));

const { iso, epochDay } = todayInTaipei();
const idx = pickDailyIndex(epochDay, poems.length);
const todayPoem = poems[idx];
const firstAllusion = todayPoem?.data.allusions[0];
const allusion = firstAllusion ? allusionById.get(firstAllusion.ref.id) : undefined;

// 卡序依 GSC 近 28 天實測需求（廟宇 ≫ 籤詩 > 神明 > 農民曆 > 習俗 > 活動）；
// 廟宇原缺卡、實為最大需求模組故補上並置首；行業守護神為新模組（乙案強入口）。
const modules = [
  { href: '/temples', label: '廟宇資料庫', desc: '主祀神明、縣市鄉鎮瀏覽、名廟沿革' },
  { href: '/poems', label: '籤詩解碼', desc: '六十甲子籤，四句＋典故＋分項解' },
  { href: '/deities', label: '神明圖譜', desc: '七大類、職司、聖誕、關係網' },
  { href: '/almanac', label: '農民曆', desc: '干支建除、宜忌考據化（建置中）' },
  { href: '/trades', label: '行業守護神', desc: '考生拜文昌、商家拜關公、行業吉日' },
  { href: '/practices', label: '拜拜習俗', desc: '科儀步驟、金紙供品' },
  { href: '/events', label: '民俗活動', desc: '遶境進香、文資身分' },
];

// 熱門神明：直連旗艦獨特頁，把離首頁的跳數壓到 1，
// 引導爬蟲與權重流向真正有搜尋需求的內容頁（依 GSC 實測曝光查詢挑選）。
const featuredDeities = [
  { id: 'mazu', name: '媽祖' },
  { id: 'yuelao', name: '月老' },
  { id: 'guangong', name: '關聖帝君' },
  { id: 'guangze', name: '廣澤尊王' },
  { id: 'nazha', name: '中壇元帥' },
  { id: 'baosheng', name: '保生大帝' },
  { id: 'chenghuang', name: '城隍爺' },
];
---

<Base
  description="神酷（神庫）：台灣民俗信仰知識系統——籤詩解讀、神明關係圖譜、廟宇文化與農民曆，逐條掛來源、諸說並陳。"
  ogTitle="神酷｜查月老籤、媽祖信仰與台灣民俗百科"
>
  <header class="brand-hero">
    <h1>神酷<span class="alt">（神庫）</span></h1>
    <p class="tagline">查籤詩、看神明、懂台灣民俗</p>
  </header>
  <section class="hero">
    <p class="kicker">今日選讀 · {iso}（全站同一支）</p>
    {
      todayPoem && (
        <article class="daily card">
          <header class="daily-head">
            <h2>
              <a href={`/poems/${todayPoem.id}`}>
                第 {todayPoem.data.no} 籤 · {todayPoem.data.ganzhi}
              </a>
            </h2>
            <span class="gua">{todayPoem.data.gua && `${todayPoem.data.gua}卦`}</span>
          </header>
          <p class="lines-vertical daily-lines">
            {todayPoem.data.lines.map((l) => <span class="line">{l}</span>)}
          </p>
          {allusion && (
            <p class="allusion-hint">
              卦頭故事：<a href={`/allusions/${allusion.id}`}>{allusion.data.name}</a>
              {allusion.data.source && <span class="muted">（{allusion.data.source}）</span>}
            </p>
          )}
          <p class="daily-cta">
            <a href={`/poems/${todayPoem.id}`}>讀解碼：四句賞析 · 典故 · 分項解 →</a>
          </p>
        </article>
      )
    }
    <p class="note muted">
      每日一籤為策展（像每日一詩），同日全站一致、不因人隨機、不標個人運勢。
    </p>
    <p class="explore">
      <a href="/poems">自由查號／瀏覽全部籤詩 →</a>
      <button id="cast" type="button" class="cast-btn" data-ids={allPoemIds.join(',')}>擲一支</button>
      <span class="muted small">（隨機瀏覽探索，非問事）</span>
    </p>
    <script is:inline>
      document.getElementById('cast')?.addEventListener('click', (e) => {
        const ids = e.currentTarget.dataset.ids.split(',');
        location.href = '/poems/' + ids[Math.floor(Math.random() * ids.length)];
      });
    </script>
  </section>

  <section class="modules">
    <h2>由此深掘</h2>
    <div class="grid cols">
      {
        modules.map((m) => (
          <a class="module card" href={m.href}>
            <strong>{m.label}</strong>
            <span class="muted">{m.desc}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="featured">
    <h2>熱門神明</h2>
    <p class="featured-links">
      {
        featuredDeities.map((d) => (
          <a href={`/deities/${d.id}`}>{d.name}</a>
        ))
      }
      <a class="more" href="/deities">看全部神明 →</a>
    </p>
  </section>

  <style>
    .brand-hero { margin: 0.5rem 0 1.5rem; }
    .brand-hero h1 { margin: 0; font-size: 2rem; letter-spacing: 0.1em; color: var(--accent); }
    .brand-hero h1 .alt { color: var(--ink-soft); font-size: 1.2rem; font-weight: 400; }
    .brand-hero .tagline { margin: 0.2rem 0 0; color: var(--ink-soft); letter-spacing: 0.08em; }
    .kicker { color: var(--gold); letter-spacing: 0.1em; font-size: 0.9rem; margin: 0 0 0.5rem; }
    .daily { border-color: var(--accent-soft); }
    .daily-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
    .daily-head h2 { margin: 0; font-size: 1.5rem; }
    .daily-head h2 a { color: var(--ink); }
    .gua { color: var(--accent); font-weight: 700; }
    .daily-lines { margin: 1.2rem 0; }
    .daily-lines .line { display: block; }
    .allusion-hint { margin: 0.6rem 0 0.2rem; }
    .daily-cta { margin: 0.8rem 0 0; font-weight: 700; }
    .note { font-size: 0.9rem; margin-top: 1rem; }
    .explore { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 0.9rem; margin: 0.3rem 0 0; }
    .cast-btn {
      font-family: inherit; font-size: 0.95rem; cursor: pointer;
      color: var(--paper-2); background: var(--accent); border: none;
      padding: 0.25rem 0.9rem; border-radius: 1rem;
    }
    .cast-btn:hover { background: var(--accent-soft); }
    .small { font-size: 0.85rem; }
    .modules { margin-top: 2.5rem; }
    .module { display: flex; flex-direction: column; gap: 0.25rem; }
    .module strong { color: var(--ink); }
    .featured { margin-top: 2rem; }
    .featured-links { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: baseline; }
    .featured-links a { font-weight: 700; }
    .featured-links .more { font-weight: 400; color: var(--ink-soft); }
  </style>
</Base>
