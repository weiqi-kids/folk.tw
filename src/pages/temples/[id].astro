---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import Sources from '../../components/Sources.astro';
import { getTemples, getDeities, getEvents, getSystems } from '../../lib/queries';
import { breadcrumb, faqPage, templePlace } from '../../lib/seo';
import { templeCounty, templeTownship } from '../../lib/temple-region';
import { lunarDateLabel } from '../../lib/birthdays';

export const getStaticPaths = (async () => {
  const temples = await getTemples();
  return temples.map((t) => ({ params: { id: t.id }, props: { temple: t } }));
}) satisfies GetStaticPaths;

const { temple } = Astro.props;
const t = temple.data;
const deities = await getDeities();
const deityName = new Map(deities.map((d) => [d.id, d.data.name]));
const deityData = new Map(deities.map((d) => [d.id, d.data]));
const systems = await getSystems();
const systemName = new Map(systems.map((s) => [s.id, s.data.name]));
const events = await getEvents();
// 此廟主辦之活動（host_temple 對映 temple.id）
const hostedEvents = events.filter((e) => e.data.host_temple === temple.id);
const refOk = t.main_deity_ref && deityName.has(t.main_deity_ref);
// 上行連結：縣市→鄉鎮二級樞紐（給爬蟲/讀者橫向出口，不建廟對廟密網）。
const county = templeCounty(t.district);
const township = templeTownship(t.district);
// 名廟沿革（#1 內容豐化）：有沿革才顯示沿革區塊。
const hasHistory = !!(t.founded || t.history || t.main_festival);

// P1-4 AEO：廟宇資料稀疏，僅就有資料者生問答。
const mainDeity = t.main_deity_raw ?? (refOk ? deityName.get(t.main_deity_ref!) : '');

// 求籤入口（主題集群邊）：把廟宇頁流量（全站曝光大宗）以 1 跳導入高 CTR 的籤詩集群。
// 僅取主祀神既有的 deity↔籤系 對映（無對映或無籤系則不顯示），不補任何新事實。
const lingqianSystems = refOk ? (deityData.get(t.main_deity_ref!)?.divination_systems ?? []) : [];

// 主祀神聖誕（農曆）：僅取 deity 節點既有 birthday_lunar 中 kind==='聖誕' 者，轉中文標籤；無源不補。
const birthdayLunar = refOk
  ? ((deityData.get(t.main_deity_ref!)?.birthday_lunar ?? []).find((b: { kind?: string; date?: string }) => b.kind === '聖誕')?.date ?? '')
  : '';
const birthdayLabel = birthdayLunar ? lunarDateLabel(birthdayLunar) : '';

// answer-first 摘要（全體廟頁皆有）：純用既有欄位重組，緊扣「XX宮是什麼廟／在哪／拜誰」搜尋意圖，絕不補新事實。
const regionLabelForSummary = county ? `${county.name}${township?.name ?? ''}` : (t.district ?? '');
const historyFirstSentence = t.history ? (t.history.split(/(?<=[。！？])/)[0] ?? '').trim() : '';
const summaryText = [
  `${t.name}`,
  regionLabelForSummary ? `位於${regionLabelForSummary}` : '',
  mainDeity ? `，主祀${mainDeity}` : '',
  birthdayLabel ? `（聖誕${birthdayLabel}）` : '',
  lingqianSystems.length > 0 ? '，可線上求籤解籤' : '',
  '。',
  historyFirstSentence ? `${historyFirstSentence}${/[。！？]$/.test(historyFirstSentence) ? '' : '。'}` : '',
].join('');

// speakable 對全體廟頁生效：以頁首 .summary 直答區塊為主（不再只限有沿革者）。
const speakable = ['h1', '.summary'];

// 廟宇頁 meta description（原本無此 prop、全站落回首頁通用文案，
// 與搜尋詞如「台南○○宮」不匹配）：僅用既有欄位（縣市鄉鎮／主祀／沿革）組成，不補新事實。
const regionLabel = county ? `${county.name}${township?.name ?? ''}` : '';
const introBits = [regionLabel && `位於${regionLabel}`, mainDeity && `主祀${mainDeity}`].filter(Boolean);
const templeDesc = `${t.name}${introBits.length ? introBits.join('，') + '。' : '。'}${t.history ?? '神酷（folk.tw）廟宇資料庫收錄，資料源自內政部全國宗教資訊網。'}`;

// 廟宇頁 title：原本僅 t.name，導致大量同名廟（慶安宮／福德宮…）落回完全相同標題、無在地辨識度。
// 全站 7891 廟 100% 具 district，加上鄉鎮地名可消歧並強化在地搜尋匹配（僅用既有欄位，不補新事實）。
const templeTitle = regionLabel ? `${t.name}・${regionLabel}` : (t.district ? `${t.name}・${t.district}` : t.name);

// FAQ（AEO）：全數就既有欄位出題，faqPage 會過濾空答；無資料的題目不生，絕不杜撰。
const lingqianNames = lingqianSystems.map((s) => systemName.get(s.id) ?? s.id);
const festivalOrHistory = t.main_festival
  ? `${t.name}的主要祭典為${t.main_festival}。`
  : historyFirstSentence
    ? `${historyFirstSentence}${/[。！？]$/.test(historyFirstSentence) ? '' : '。'}`
    : '';
const faq = faqPage([
  {
    q: `${t.name}主祀哪位神明？`,
    a: mainDeity
      ? `${t.name}主祀${mainDeity}${birthdayLabel ? `，聖誕為${birthdayLabel}` : ''}。`
      : '',
  },
  {
    q: `${t.name}在哪裡？`,
    a: regionLabelForSummary ? `${t.name}位於${regionLabelForSummary}。` : (t.district ? `${t.name}位於${t.district}。` : ''),
  },
  {
    q: `${t.name}可以求籤嗎？`,
    a: lingqianNames.length > 0 ? `可以。${t.name}主祀${mainDeity}，可線上查閱${lingqianNames.join('、')}與白話解籤。` : '',
  },
  {
    q: t.main_festival ? `${t.name}的主要祭典是什麼？` : `${t.name}的沿革為何？`,
    a: festivalOrHistory,
  },
]);

const jsonLd = [
  templePlace({
    id: temple.id,
    name: t.name,
    deity: mainDeity || undefined,
    address: t.district,
    lat: t.lat,
    lng: t.lng,
    website: t.website,
  }),
  breadcrumb([
    { name: '廟宇', path: '/temples/' },
    { name: t.name, path: `/temples/${temple.id}/` },
  ]),
  ...(faq ? [faq] : []),
];
---

<Base title={templeTitle} description={templeDesc} ogType="article" jsonLd={jsonLd} speakable={speakable}>
  <nav class="crumb">
    <a href="/temples/">廟宇</a>
    {county && <> ／ <a href={`/temples/region/${county.slug}/`}>{county.name}</a></>}
    {county && township && <> ／ <a href={`/temples/region/${county.slug}/${township.name}/`}>{township.name}</a></>}
  </nav>
  <h1>{t.name}</h1>

  <p class="summary">{summaryText}</p>

  <dl class="rec">
    {t.district && <div><dt>行政區</dt><dd>{t.district}</dd></div>}
    <div>
      <dt>主祀神祇</dt>
      <dd>
        {t.main_deity_raw}
        {refOk ? (
          <span> · <a href={`/deities/${t.main_deity_ref}/`}>{deityName.get(t.main_deity_ref!)}（圖譜）</a></span>
        ) : (
          t.main_deity_raw && <span class="muted small"> · 未對映神明節點</span>
        )}
      </dd>
    </div>
    {
      t.lng != null && t.lat != null && (
        <div>
          <dt>座標</dt>
          <dd>
            {t.lat}, {t.lng}
            <a class="map" href={`https://www.openstreetmap.org/?mlat=${t.lat}&mlon=${t.lng}#map=17/${t.lat}/${t.lng}/`} target="_blank" rel="noopener">地圖 ↗</a>
          </dd>
        </div>
      )
    }
  </dl>

  {
    lingqianSystems.length > 0 && (
      <section class="temple-lingqian">
        <h2>到{t.name}求籤</h2>
        <p class="muted small">{mainDeity}的靈籤，可線上查閱籤詩與白話解籤：</p>
        <ul>
          {lingqianSystems.map((s) => (
            <li><a href={`/systems/${s.id}/`}>{systemName.get(s.id) ?? s.id}</a></li>
          ))}
        </ul>
      </section>
    )
  }

  {
    hasHistory && (
      <section class="temple-history">
        <h2>沿革</h2>
        {t.founded && <p class="founded"><strong>創建</strong>　{t.founded}</p>}
        {t.history && <p class="history-body">{t.history}</p>}
        {t.main_festival && <p class="festival"><strong>主要祭典</strong>　{t.main_festival}</p>}
      </section>
    )
  }

  {
    hostedEvents.length > 0 && (
      <section>
        <h2>主辦民俗活動</h2>
        <ul>
          {hostedEvents.map((e) => (
            <li><a href={`/events/${e.id}/`}>{e.data.name}</a></li>
          ))}
        </ul>
      </section>
    )
  }

  {county && township && (
    <p class="region-link"><a href={`/temples/region/${county.slug}/${township.name}/`}>查看{county.name}{township.name}其他廟宇 →</a></p>
  )}
  {county && !township && (
    <p class="region-link"><a href={`/temples/region/${county.slug}/`}>查看{county.name}全部廟宇 →</a></p>
  )}

  {t.website && <p class="temple-site"><a href={t.website} target="_blank" rel="noopener">官方網站 →</a></p>}

  {t.sources.length > 0 && <p class="src"><Sources sources={t.sources} /></p>}

  <style>
    .crumb { color: var(--ink-soft); font-size: var(--text-sm); margin-bottom: 0.5rem; }
    .summary { font-size: var(--text-base); line-height: 1.8; margin: 0.6rem 0 1rem; }
    .rec { display: grid; gap: 0.4rem; margin: 1rem 0; }
    .rec > div { display: grid; grid-template-columns: 6rem 1fr; gap: 0.5rem; padding: 0.3rem 0; border-bottom: 1px dashed var(--line); }
    .rec dt { font-weight: 700; color: var(--accent); }
    .rec dd { margin: 0; }
    .map { margin-left: 0.6rem; font-size: var(--text-sm); }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; }
    .small { font-size: var(--text-sm); }
    .temple-history { margin-top: 1.2rem; }
    .temple-history .history-body { line-height: 1.8; }
    .temple-history .founded, .temple-history .festival { margin: 0.4rem 0; }
    .temple-history strong { color: var(--accent); margin-right: 0.3rem; }
    .region-link { margin-top: 1.2rem; font-size: var(--text-sm); }
    .region-link a { font-weight: 600; }
    .temple-site { margin-top: 1rem; font-size: var(--text-sm); }
    .temple-site a { font-weight: 600; }
    .src { color: var(--gold); font-size: var(--text-xs); margin-top: 1.5rem; }
  </style>
</Base>
