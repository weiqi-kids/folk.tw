---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import { getTemples, getDeities, getEvents } from '../../lib/queries';
import { breadcrumb, faqPage, templePlace } from '../../lib/seo';
import { templeCounty } from '../../lib/temple-region';

export const getStaticPaths = (async () => {
  const temples = await getTemples();
  return temples.map((t) => ({ params: { id: t.id }, props: { temple: t } }));
}) satisfies GetStaticPaths;

const { temple } = Astro.props;
const t = temple.data;
const deities = await getDeities();
const deityName = new Map(deities.map((d) => [d.id, d.data.name]));
const events = await getEvents();
// 此廟主辦之活動（host_temple 對映 temple.id）
const hostedEvents = events.filter((e) => e.data.host_temple === temple.id);
const refOk = t.main_deity_ref && deityName.has(t.main_deity_ref);
// 上行連結：同縣市廟宇頁（單一 hub 連結，給爬蟲/讀者橫向出口，不建廟對廟密網）。
const county = templeCounty(t.district);

// P1-4 AEO：廟宇資料稀疏，僅就有資料者生問答。
const mainDeity = t.main_deity_raw ?? (refOk ? deityName.get(t.main_deity_ref!) : '');
const faq = faqPage([
  {
    q: `${t.name}主祀哪位神明？`,
    a: mainDeity ? `${t.name}主祀${mainDeity}。` : '',
  },
  {
    q: `${t.name}在哪裡？`,
    a: t.district ? `${t.name}位於${t.district}。` : '',
  },
]);

const jsonLd = [
  templePlace({
    id: temple.id,
    name: t.name,
    deity: mainDeity || undefined,
    address: t.district,
    lat: t.lat,
    lng: t.lng,
    website: t.website,
  }),
  breadcrumb([
    { name: '廟宇', path: '/temples' },
    { name: t.name, path: `/temples/${temple.id}` },
  ]),
  ...(faq ? [faq] : []),
];
---

<Base title={t.name} ogType="article" jsonLd={jsonLd}>
  <nav class="crumb">
    <a href="/temples">廟宇</a>
    {county && <> ／ <a href={`/temples/region/${county.slug}`}>{county.name}</a></>}
  </nav>
  <h1>{t.name}</h1>

  <dl class="rec">
    {t.district && <div><dt>行政區</dt><dd>{t.district}</dd></div>}
    <div>
      <dt>主祀神祇</dt>
      <dd>
        {t.main_deity_raw}
        {refOk ? (
          <span> · <a href={`/deities/${t.main_deity_ref}`}>{deityName.get(t.main_deity_ref!)}（圖譜）</a></span>
        ) : (
          t.main_deity_raw && <span class="muted small"> · 未對映神明節點</span>
        )}
      </dd>
    </div>
    {
      t.lng != null && t.lat != null && (
        <div>
          <dt>座標</dt>
          <dd>
            {t.lat}, {t.lng}
            <a class="map" href={`https://www.openstreetmap.org/?mlat=${t.lat}&mlon=${t.lng}#map=17/${t.lat}/${t.lng}`} target="_blank" rel="noopener">地圖 ↗</a>
          </dd>
        </div>
      )
    }
  </dl>

  {
    hostedEvents.length > 0 && (
      <section>
        <h2>主辦民俗活動</h2>
        <ul>
          {hostedEvents.map((e) => (
            <li><a href={`/events/${e.id}`}>{e.data.name}</a></li>
          ))}
        </ul>
      </section>
    )
  }

  {county && (
    <p class="region-link"><a href={`/temples/region/${county.slug}`}>查看{county.name}全部廟宇 →</a></p>
  )}

  {t.website && <p class="temple-site"><a href={t.website} target="_blank" rel="noopener">官方網站 →</a></p>}

  {t.sources.length > 0 && <p class="src">來源：{t.sources.map((s) => s.ref).join('；')}</p>}

  <style>
    .crumb { color: var(--ink-soft); font-size: 0.9rem; margin-bottom: 0.5rem; }
    .rec { display: grid; gap: 0.4rem; margin: 1rem 0; }
    .rec > div { display: grid; grid-template-columns: 6rem 1fr; gap: 0.5rem; padding: 0.3rem 0; border-bottom: 1px dashed var(--line); }
    .rec dt { font-weight: 700; color: var(--accent); }
    .rec dd { margin: 0; }
    .map { margin-left: 0.6rem; font-size: 0.85rem; }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; }
    .small { font-size: 0.85rem; }
    .region-link { margin-top: 1.2rem; font-size: 0.95rem; }
    .region-link a { font-weight: 600; }
    .temple-site { margin-top: 1rem; font-size: 0.95rem; }
    .temple-site a { font-weight: 600; }
    .src { color: var(--gold); font-size: 0.82rem; margin-top: 1.5rem; }
  </style>
</Base>
