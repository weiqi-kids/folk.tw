---
import type { GetStaticPaths } from 'astro';
import Base from '../../../layouts/Base.astro';
import { getTemples } from '../../../lib/queries';
import { breadcrumb } from '../../../lib/seo';
import { ALL_COUNTIES, countyName, templeCounty, templeTownship } from '../../../lib/temple-region';

// 各縣市一頁。改為「鄉鎮市區二級樞紐」：列各鄉鎮（含廟數）連到 /region/[county]/[town]，
// 化解單一縣市頁過大（台南/高雄/屏東逾 700-1076 間）；無法判定鄉鎮者列入「其他」直連廟頁。
export const getStaticPaths = (async () => {
  const temples = await getTemples();
  return ALL_COUNTIES.map(([, slug]) => ({
    params: { county: slug },
    props: {
      slug,
      temples: temples.filter((t) => templeCounty(t.data.district)?.slug === slug),
    },
  })).filter((p) => p.props.temples.length > 0);
}) satisfies GetStaticPaths;

const { slug, temples } = Astro.props;
const name = countyName(slug) ?? slug;

// 依鄉鎮市區分組（保留原序），無法判定者歸「其他」。
const byTown = new Map<string, typeof temples>();
const other: typeof temples = [];
for (const t of temples) {
  const tw = templeTownship(t.data.district);
  if (!tw) { other.push(t); continue; }
  (byTown.get(tw.name) ?? byTown.set(tw.name, []).get(tw.name)!).push(t);
}
const towns = [...byTown.entries()].map(([town, list]) => ({ town, n: list.length }));
---

<Base
  title={`${name}廟宇`}
  description={`${name}的廟宇與主祀神祇（內政部開放資料），共 ${temples.length} 間，可依鄉鎮市區瀏覽。`}
  jsonLd={breadcrumb([
    { name: '廟宇', path: '/temples/' },
    { name, path: `/temples/region/${slug}/` },
  ])}
>
  <nav class="crumb"><a href="/temples/">廟宇</a> ／ {name}</nav>
  <h1>{name}廟宇</h1>
  <p class="muted">{name}收錄 {temples.length} 間，依鄉鎮市區瀏覽。</p>

  {
    towns.length > 0 && (
      <div class="town-wall">
        {towns.map((r) => (
          <a class="card town" href={`/temples/region/${slug}/${r.town}/`}>
            <strong>{r.town}</strong>
            <span class="muted count">{r.n}</span>
          </a>
        ))}
      </div>
    )
  }

  {
    other.length > 0 && (
      <>
        <h2>其他（鄉鎮未判定）</h2>
        <div class="grid cols">
          {other.map((t) => (
            <a class="card temple" href={`/temples/${t.id}/`}>
              <strong>{t.data.name}</strong>
              <span class="muted small">
                {t.data.district}
                {t.data.main_deity_raw && `　·　主祀 ${t.data.main_deity_raw}`}
              </span>
            </a>
          ))}
        </div>
      </>
    )
  }

  <p class="muted small src">資料來源：內政部全國宗教資訊網開放資料。</p>
  <style>
    .crumb { color: var(--ink-soft); font-size: var(--text-sm); margin-bottom: 0.5rem; }
    .town-wall {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(7.5rem, 1fr));
      gap: 0.6rem;
    }
    .town {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.6rem 0.85rem;
      margin: 0;
    }
    .town strong { color: var(--ink); }
    .town .count { font-size: var(--text-sm); }
    .temple { display: flex; flex-direction: column; gap: 0.25rem; }
    .temple strong { color: var(--ink); }
    .small { font-size: 0.85rem; }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-top: 1.6rem; }
    .src { margin-top: 1.5rem; color: var(--gold); }
  </style>
</Base>
