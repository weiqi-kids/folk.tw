---
import Base from '../../layouts/Base.astro';
import { getTemples } from '../../lib/queries';
import { breadcrumb } from '../../lib/seo';
import { ALL_COUNTIES, templeCounty } from '../../lib/temple-region';

const temples = await getTemples();
// 依縣市計數（取代原本 2.1MB 全廟平面清單，改為分層瀏覽，利使用者與爬蟲）。
const counts = new Map<string, number>();
let unknown = 0;
for (const t of temples) {
  const c = templeCounty(t.data.district);
  if (c) counts.set(c.slug, (counts.get(c.slug) ?? 0) + 1);
  else unknown++;
}
const regions = ALL_COUNTIES.map(([name, slug]) => ({ name, slug, n: counts.get(slug) ?? 0 })).filter(
  (r) => r.n > 0,
);
// 精選名廟（非 MOI 匯入）置頂，保留入口。
const featured = temples.filter((t) => !t.id.startsWith('moi_')).slice(0, 28);
---

<Base
  title="廟宇"
  description={`收錄全台 ${temples.length} 間廟宇與主祀神祇（內政部開放資料），可依縣市瀏覽，主祀神連回神明圖譜。`}
  jsonLd={breadcrumb([{ name: '廟宇', path: '/temples' }])}
>
  <h1>廟宇</h1>
  <p class="muted">收錄全台 {temples.length} 間廟宇（內政部開放資料）。依縣市瀏覽，或先看代表名廟。</p>

  <h2>依縣市瀏覽</h2>
  <div class="county-wall">
    {
      regions.map((r) => (
        <a class="card county" href={`/temples/region/${r.slug}/`}>
          <strong>{r.name}</strong>
          <span class="muted count">{r.n}</span>
        </a>
      ))
    }
  </div>

  {
    featured.length > 0 && (
      <>
        <h2>代表名廟</h2>
        <div class="grid cols">
          {featured.map((t) => (
            <a
              class:list={['card', 'temple', { 'card-photo': t.data.image }]}
              href={`/temples/${t.id}/`}
            >
              <strong>{t.data.name}</strong>
              <span class="muted small">
                {t.data.district}
                {t.data.main_deity_raw && `　·　主祀 ${t.data.main_deity_raw}`}
              </span>
              {t.data.image && (
                <img
                  class="card-photo-img"
                  src={t.data.image.src}
                  alt={t.data.image.alt}
                  title={`圖：${t.data.image.author}　·　${t.data.image.license}（Wikimedia Commons，詳見關於頁）`}
                  width="72"
                  height="72"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </a>
          ))}
        </div>
      </>
    )
  }

  <p class="muted small src">資料來源：內政部全國宗教資訊網開放資料。{unknown > 0 && `（另有 ${unknown} 間縣市未判定）`}</p>
  <style>
    .county-wall {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(7.5rem, 1fr));
      gap: 0.6rem;
      margin-top: 1rem;
    }
    .county {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.6rem 0.85rem;
      margin: 0;
    }
    .county strong { color: var(--ink); }
    .county .count { font-size: var(--text-sm); }
    .temple { display: flex; flex-direction: column; gap: 0.25rem; }
    .temple strong { color: var(--ink); }
    .small { font-size: 0.98rem; }
    .temple .muted { color: oklch(0.37 0.02 72); }
    .src { margin-top: 1.5rem; color: var(--gold); }
  </style>
</Base>
