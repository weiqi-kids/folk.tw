---
// 全站共用版面。設計：考據領銜、克制；四句/典故/白話為主角，吉凶輔標小（§0.5）。
interface Props {
  title?: string;
  description?: string;
  ogTitle?: string; // 社群分享專用標題（不給則同 fullTitle）
  jsonLd?: object | object[]; // 每頁實體結構化資料（BreadcrumbList / Thing / CreativeWork…）
  noindex?: boolean; // 對搜尋引擎不索引（如農民曆滾動日期頁，避免視窗滾動後 404 與薄內容稀釋）
  ogType?: string; // Open Graph 類型；列表／首頁用 'website'，內容／詳情頁傳 'article'
  speakable?: string[]; // AEO：可朗讀／可被語音助理與 AI 答案引擎擷取為直接答案的元素 CSS 選擇器（如 ['h1', '.summary']）
}
import { GA4_ID } from '../consts';
import '../styles/global.css'; // 統一設計 token（OKLCH 配色＋字級階梯＋放大基準字）
// ogType 預設 'website'；內容／詳情頁（如籤詩、神明、農民曆日期頁）請傳 'article'
const { title, description, ogTitle, jsonLd: pageJsonLd, noindex, ogType = 'website', speakable } = Astro.props;
const pageLd = pageJsonLd ? (Array.isArray(pageJsonLd) ? pageJsonLd : [pageJsonLd]) : [];
const siteName = '神酷';
// 瀏覽器標題（SEO）：首頁用品牌＋三大核心；內頁用「頁名｜神酷」
const fullTitle = title
  ? `${title}｜${siteName}`
  : '神酷｜台灣民俗信仰資料庫、籤詩解讀與神明關係圖譜';
const ogFullTitle = ogTitle ?? fullTitle; // OG 標題（社群分享）
const desc = description ?? '神酷（神庫）：台灣民俗信仰知識系統——籤詩解讀、神明關係圖譜、廟宇文化與農民曆，逐條掛來源、諸說並陳。';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://folk.tw').href;
// Schema.org：以「知識系統 / 資料庫」呈現（非單純 website），利 AI 理解與引用（GEO）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: '神酷（神庫）— 台灣民俗信仰知識系統',
  alternateName: ['神酷', '神庫', 'Shenku (Taiwan Folk Knowledge Graph System)'],
  url: 'https://folk.tw',
  description:
    'A structured knowledge system for Taiwanese folk beliefs, including deity relationships, divination poems, temple culture, and ritual traditions.（台灣民俗信仰結構化知識系統：神明關係、籤詩解讀、廟宇文化、科儀傳統）',
  inLanguage: 'zh-Hant-TW',
  about: [
    'Taiwan folk religion',
    'divination poetry interpretation',
    'deity relationship graph',
    'temple culture knowledge base',
    'folk tradition archive',
  ],
  keywords: ['月老籤', '媽祖', '王爺', '籤詩', '台灣民俗', '農民曆'],
  creator: { '@type': 'Organization', name: '神酷', alternateName: '神庫' },
  license: 'https://github.com/weiqi-kids/folk.tw/blob/main/LICENSE',
};
// WebSite + SearchAction：宣告站內全文檢索端點，利 Google 顯示 sitelinks 搜尋框（搭配 /search?q=）。
const webSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  alternateName: ['神酷', '神庫'],
  url: 'https://folk.tw',
  inLanguage: 'zh-Hant-TW',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://folk.tw/search?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
// speakable（AEO）：宣告頁面最適合被語音助理朗讀／AI 答案引擎擷取為直接答案的區塊（answer-first）。
// 僅內容詳情頁傳入；cssSelector 指向實際存在之標題與摘要元素（不存在則消費端自動略過，無害）。
const speakablePage =
  speakable && speakable.length
    ? {
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        '@id': canonical,
        url: canonical,
        name: fullTitle,
        inLanguage: 'zh-Hant-TW',
        speakable: { '@type': 'SpeakableSpecification', cssSelector: speakable },
      }
    : null;
const nav = [
  { href: '/', label: '今日' },
  { href: '/poems', label: '籤詩' },
  { href: '/deities', label: '神明' },
  { href: '/almanac', label: '農民曆' },
  { href: '/events', label: '民俗活動' },
  { href: '/practices', label: '拜拜習俗' },
  { href: '/temples', label: '廟宇' },
  { href: '/search', label: '搜尋' },
  { href: '/about', label: '關於' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonical} />
    {/* 圖示：SVG（現代瀏覽器）＋ PNG/ICO 後備（Safari/iOS、Google 搜尋結果需點陣）＋ PWA manifest */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {/* Open Graph / Twitter */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogFullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:image" content="https://folk.tw/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="神酷（神庫）— 台灣民俗信仰知識系統" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://folk.tw/og.png" />
    <meta name="theme-color" content="#8a2b2b" />
    {/* Schema.org 知識系統標註（GEO：利 AI 理解為 knowledge system 而非單純網站） */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(webSite)} />
    {speakablePage && <script type="application/ld+json" is:inline set:html={JSON.stringify(speakablePage)} />}
    {pageLd.map((ld) => <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />)}
    {/* Google Analytics 4（GA4_ID 留空則不載入；見 src/consts.ts）
        延後載入 gtag.js：指令先入 dataLayer 佇列（不漏 page_view），實際下載等
        瀏覽器閒置或首次互動，避免載入期佔用主執行緒（壓低 TBT）。 */}
    {
      GA4_ID && (
        <script is:inline define:vars={{ GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_ID, { anonymize_ip: true });
          var loadGA = function () {
            if (window.__gaLoaded) return;
            window.__gaLoaded = true;
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
            document.head.appendChild(s);
          };
          if ('requestIdleCallback' in window) requestIdleCallback(loadGA, { timeout: 4000 });
          else window.addEventListener('load', function () { setTimeout(loadGA, 1500); });
          ['scroll', 'click', 'keydown', 'touchstart', 'pointerdown'].forEach(function (e) {
            window.addEventListener(e, loadGA, { once: true, passive: true });
          });
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">神酷</a>
      <nav>
        {
          nav.map((n) => (
            <a
              href={n.href}
              class:list={[{ active: n.href === '/' ? path === '/' : path.startsWith(n.href) }]}
            >
              {n.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main class="site-main" data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <p class="scope">
        本站涵蓋以<strong>漢人民間信仰</strong>為主（七大類），非窮盡台灣所有宗教信仰；未涵蓋原住民族傳統信仰、佛教各宗等。
      </p>
      <p class="disclaim">
        本站為民俗文化考據與教育呈現，<strong>不構成醫療、法律、投資、命理或宗教指導建議</strong>。
        內容涉健康／法律／財務／心理者，請洽專業人士。
      </p>
      <p class="meta">
        籤詩本文屬公有領域；解語、白話與摘要為本站撰寫或標明出處。
        資料逐條掛來源、無源不發佈。<a href="/about">關於與勘誤 →</a>
      </p>
    </footer>
  </body>
</html>
