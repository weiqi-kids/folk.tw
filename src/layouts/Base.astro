---
// 全站共用版面。設計：考據領銜、克制；四句/典故/白話為主角，吉凶輔標小（§0.5）。
interface Props {
  title?: string;
  description?: string;
  ogTitle?: string; // 社群分享專用標題（不給則同 fullTitle）
  jsonLd?: object | object[]; // 每頁實體結構化資料（BreadcrumbList / Thing / CreativeWork…）
}
import { GA4_ID } from '../consts';
const { title, description, ogTitle, jsonLd: pageJsonLd } = Astro.props;
const pageLd = pageJsonLd ? (Array.isArray(pageJsonLd) ? pageJsonLd : [pageJsonLd]) : [];
const siteName = '神酷';
// 瀏覽器標題（SEO）：首頁用品牌＋三大核心；內頁用「頁名｜神酷」
const fullTitle = title
  ? `${title}｜${siteName}`
  : '神酷｜台灣民俗信仰資料庫、籤詩解讀與神明關係圖譜';
const ogFullTitle = ogTitle ?? fullTitle; // OG 標題（社群分享）
const desc = description ?? '神酷（神庫）：台灣民俗信仰知識系統——籤詩解讀、神明關係圖譜、廟宇文化與農民曆，逐條掛來源、諸說並陳。';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://folk.tw').href;
// Schema.org：以「知識系統 / 資料庫」呈現（非單純 website），利 AI 理解與引用（GEO）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: '神酷（神庫）— 台灣民俗信仰知識系統',
  alternateName: ['神酷', '神庫', 'Shenku (Taiwan Folk Knowledge Graph System)'],
  url: 'https://folk.tw',
  description:
    'A structured knowledge system for Taiwanese folk beliefs, including deity relationships, divination poems, temple culture, and ritual traditions.（台灣民俗信仰結構化知識系統：神明關係、籤詩解讀、廟宇文化、科儀傳統）',
  inLanguage: 'zh-Hant-TW',
  about: [
    'Taiwan folk religion',
    'divination poetry interpretation',
    'deity relationship graph',
    'temple culture knowledge base',
    'folk tradition archive',
  ],
  keywords: ['月老籤', '媽祖', '王爺', '籤詩', '台灣民俗', '農民曆'],
  creator: { '@type': 'Organization', name: '神酷', alternateName: '神庫' },
  license: 'https://github.com/weiqi-kids/folk.tw/blob/main/LICENSE',
};
const nav = [
  { href: '/', label: '今日' },
  { href: '/poems', label: '籤詩' },
  { href: '/deities', label: '神明' },
  { href: '/almanac', label: '農民曆' },
  { href: '/events', label: '民俗活動' },
  { href: '/practices', label: '拜拜習俗' },
  { href: '/temples', label: '廟宇' },
  { href: '/search', label: '搜尋' },
  { href: '/about', label: '關於' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Open Graph / Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogFullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:image" content="https://folk.tw/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="神酷（神庫）— 台灣民俗信仰知識系統" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://folk.tw/og.png" />
    <meta name="theme-color" content="#8a2b2b" />
    {/* Schema.org 知識系統標註（GEO：利 AI 理解為 knowledge system 而非單純網站） */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    {pageLd.map((ld) => <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />)}
    {/* Google Analytics 4（GA4_ID 留空則不載入；見 src/consts.ts） */}
    {
      GA4_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}
          ></script>
          <script is:inline define:vars={{ GA4_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', GA4_ID, { anonymize_ip: true });
          </script>
        </>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">神酷</a>
      <nav>
        {
          nav.map((n) => (
            <a
              href={n.href}
              class:list={[{ active: n.href === '/' ? path === '/' : path.startsWith(n.href) }]}
            >
              {n.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main class="site-main" data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <p class="scope">
        本站涵蓋以<strong>漢人民間信仰</strong>為主（七大類），非窮盡台灣所有宗教信仰；未涵蓋原住民族傳統信仰、佛教各宗等。
      </p>
      <p class="disclaim">
        本站為民俗文化考據與教育呈現，<strong>不構成醫療、法律、投資、命理或宗教指導建議</strong>。
        內容涉健康／法律／財務／心理者，請洽專業人士。
      </p>
      <p class="meta">
        籤詩本文屬公有領域；解語、白話與摘要為本站撰寫或標明出處。
        資料逐條掛來源、無源不發佈。<a href="/about">關於與勘誤 →</a>
      </p>
    </footer>
    <style is:global>
      :root {
        --ink: #1c1a17;
        --ink-soft: #4a443c;
        --paper: #f7f3ea;
        --paper-2: #fffdf8;
        --line: #ddd3c0;
        --accent: #8a2b2b; /* 朱 */
        --accent-soft: #b56b4a;
        --gold: #9a7b3f;
        --max: 56rem;
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: 'Noto Serif TC', 'Source Han Serif TC', '本蘭明體', serif;
        color: var(--ink);
        background: var(--paper);
        line-height: 1.75;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .site-header {
        display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem 1.5rem;
        max-width: var(--max); margin: 0 auto; padding: 1.2rem 1.25rem 0.8rem;
        border-bottom: 2px solid var(--accent);
      }
      .brand { font-size: 1.4rem; font-weight: 700; color: var(--ink); letter-spacing: 0.08em; }
      .site-header nav { display: flex; flex-wrap: wrap; gap: 0.25rem 1.1rem; margin-left: auto; }
      .site-header nav a { color: var(--ink-soft); font-size: 0.98rem; }
      .site-header nav a.active { color: var(--accent); font-weight: 700; }
      .site-main { max-width: var(--max); margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
      .site-footer {
        max-width: var(--max); margin: 0 auto; padding: 1.5rem 1.25rem 2.5rem;
        border-top: 1px solid var(--line); color: var(--ink-soft); font-size: 0.86rem;
      }
      .site-footer p { margin: 0.4rem 0; }
      .site-footer .meta { color: var(--gold); }
      h1, h2, h3 { line-height: 1.35; }
      .tag {
        display: inline-block; font-size: 0.78rem; padding: 0.05rem 0.5rem;
        border: 1px solid var(--line); border-radius: 1rem; color: var(--ink-soft);
        background: var(--paper-2); margin: 0 0.2rem 0.2rem 0;
      }
      .tag.fortune { border-color: var(--accent-soft); color: var(--accent); }
      .card {
        background: var(--paper-2); border: 1px solid var(--line);
        border-radius: 0.5rem; padding: 1.1rem 1.25rem; margin: 0.8rem 0;
      }
      .muted { color: var(--ink-soft); }
      .pending {
        color: var(--gold); font-size: 0.85rem; font-style: italic;
        border-left: 3px solid var(--line); padding-left: 0.7rem; margin: 0.6rem 0;
      }
      .grid { display: grid; gap: 0.75rem; }
      .grid.cols { grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); }
      .lines-vertical {
        font-size: 1.5rem; letter-spacing: 0.15em; line-height: 2.2;
      }
    </style>
  </body>
</html>
