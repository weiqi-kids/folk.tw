{
  "name": "folk.tw",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:integrity": "node --experimental-strip-types scripts/check-integrity.ts",
    "check:canonical": "node scripts/check-canonical-links.mjs",
    "check:rendered": "node scripts/check-rendered.mjs",
    "import:temples": "node --experimental-strip-types scripts/import-temples.ts",
    "verify:almanac": "node --experimental-strip-types scripts/verify-almanac.ts",
    "data:seo-daily": "node scripts/seo-daily.mjs",
    "data:weekly": "node scripts/seo-weekly.mjs --dry",
    "index:ping": "node scripts/index-ping.mjs",
    "indexnow:ping": "node scripts/indexnow-ping.mjs",
    "notify": "node scripts/notify.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.7",
    "lunar-javascript": "^1.7.7",
    "solarlunar": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.0.0",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3"
  }
}
